+        bld.entries = ble;
+        passBGL = wgpuDeviceCreateBindGroupLayout(device, &bld);
+        WGPUPipelineLayoutDescriptor pld = {};
+        pld.bindGroupLayoutCount = 1;
+        pld.bindGroupLayouts = &passBGL;
