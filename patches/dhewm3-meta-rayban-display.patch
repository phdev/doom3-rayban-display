+        outCount = mainN;
+        lastUploadedCapFrameId = g_capFrameId;
+
+        // Iter 13b: upload the sky cube-dir stream before the pass sweep.
+        {
+            extern uint8_t  g_skyDirsAccum[];
+            extern uint32_t g_skyDirBytes;
+            if (g_skyDirBytes > 0 && skyPipeline) {
+                const uint32_t need = (g_skyDirBytes + 3u) & ~3u;
+                if (need > skyDirCap) {
+                    if (skyDirBuf) wgpuBufferRelease(skyDirBuf);
+                    uint32_t cap = need; if (cap < 64*1024) cap = 64*1024;
+                    WGPUBufferDescriptor d = {};
+                    d.size = cap;
+                    d.usage = WGPUBufferUsage_Vertex | WGPUBufferUsage_CopyDst;
+                    skyDirBuf = wgpuDeviceCreateBuffer(device, &d);
+                    skyDirCap = cap;
