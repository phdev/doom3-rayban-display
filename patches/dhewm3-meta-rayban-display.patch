+	const bool wgpuViewBigEnough = backEnd.viewDef &&
+		( backEnd.viewDef->viewport.x2 - backEnd.viewDef->viewport.x1 ) >= 128;
+	if ( wgpuViewBigEnough && din && din->surf && din->surf->geo
+		 && din->surf->geo->verts && din->surf->geo->indexes
+		 && din->surf->geo->numVerts > 0 && din->surf->geo->numIndexes > 0
