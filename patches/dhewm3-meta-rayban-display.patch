+// reflect.wgsl
+static const char* const kWGSL_reflect = "// reflect.wgsl — TG_REFLECT_CUBE environment mapping.\n"
+"//\n"
+"// GL used fixed-function GL_REFLECTION_MAP (eye-space reflection of the\n"
+"// per-vertex normal) with the texture matrix set to the transposed view\n"
+"// rotation, rotating the eye-space reflection into world axes for the cube\n"
+"// lookup. Same math here, per fragment.\n"
+"\n"
+"struct Uniforms {\n"
+"    mvp:        mat4x4<f32>,\n"
+"    model_view: mat4x4<f32>,   // model -> eye\n"
+"    inv_view0:  vec4<f32>,     // rows of transpose(view rotation)\n"
+"    inv_view1:  vec4<f32>,\n"
+"    inv_view2:  vec4<f32>,\n"
+"    tint:       vec4<f32>,\n"
+"};\n"
+"@group(0) @binding(0) var<uniform> u: Uniforms;\n"
+"@group(0) @binding(1) var samp: sampler;\n"
+"@group(0) @binding(2) var tcube: texture_cube<f32>;\n"
+"\n"
+"struct VSIn {\n"
+"    @location(0) position:  vec3<f32>,\n"
+"    @location(1) texcoord:  vec2<f32>,\n"
+"    @location(2) normal:    vec3<f32>,\n"
+"    @location(3) tangent:   vec3<f32>,\n"
+"    @location(4) bitangent: vec3<f32>,\n"
+"    @location(5) color:     vec4<f32>,\n"
+"};\n"
+"\n"
+"struct VSOut {\n"
+"    @builtin(position) clip_pos: vec4<f32>,\n"
+"    @location(0) n_eye: vec3<f32>,\n"
+"    @location(1) p_eye: vec3<f32>,\n"
+"};\n"
+"\n"
+"@vertex\n"
+"fn vs_main(in: VSIn) -> VSOut {\n"
+"    var out: VSOut;\n"
+"    let cp = u.mvp * vec4<f32>(in.position, 1.0);\n"
+"    out.clip_pos = vec4<f32>(cp.x, cp.y, (cp.z + cp.w) * 0.5, cp.w);\n"
+"    out.n_eye = (u.model_view * vec4<f32>(in.normal, 0.0)).xyz;\n"
+"    out.p_eye = (u.model_view * vec4<f32>(in.position, 1.0)).xyz;\n"
+"    return out;\n"
+"}\n"
+"\n"
+"@fragment\n"
+"fn fs_main(in: VSOut) -> @location(0) vec4<f32> {\n"
+"    let n = normalize(in.n_eye);\n"
+"    let v = normalize(in.p_eye);\n"
+"    let r = reflect(v, n);\n"
+"    let dir = vec3<f32>(dot(u.inv_view0.xyz, r),\n"
+"                        dot(u.inv_view1.xyz, r),\n"
+"                        dot(u.inv_view2.xyz, r));\n"
+"    return textureSample(tcube, samp, dir) * u.tint;\n"
+"}\n"
+"";
+
+// shadow.wgsl
+static const char* const kWGSL_shadow = "// shadow.wgsl — stencil shadow volume vertex shader, WGSL port of\n"
+"// glprogs/shadow.vp (VPROG_STENCIL_SHADOW).\n"
+"//\n"
+"// Shadow volume vertices are vec4s: w=1 verts are the near cap (on the\n"
+"// occluder surface); w=0 verts are projected to infinity away from the\n"
+"// light. The vertex program computes, for w=0 verts,\n"
+"//   position' = (vertex.xyz - localLightOrigin.xyz, 0)\n"
+"// and relies on the engine's infinite-far-plane projection matrix to\n"
+"// rasterize the at-infinity geometry. u.mvp here is the engine's full\n"
+"// projection*modelView baked at capture, so the same math holds.\n"
+"//\n"
+"// No fragment stage — the pipeline writes stencil only.\n"
+"\n"
+"struct Uniforms {\n"
+"    mvp:          mat4x4<f32>,\n"
+"    light_origin: vec4<f32>,   // model-space light position (.w = 0)\n"
+"};\n"
+"@group(0) @binding(0) var<uniform> u: Uniforms;\n"
+"\n"
+"struct VSIn {\n"
+"    @location(0) position: vec4<f32>,\n"
+"};\n"
+"\n"
+"struct VSOut {\n"
+"    @builtin(position) clip_pos: vec4<f32>,\n"
+"};\n"
+"\n"
+"@vertex\n"
+"fn vs_main(in: VSIn) -> VSOut {\n"
+"    var out: VSOut;\n"
+"    // w==1 → near cap vertex used as-is; w==0 → direction-to-infinity.\n"
+"    let projected = vec4<f32>(in.position.xyz - u.light_origin.xyz, 0.0);\n"
+"    let pos = select(projected, in.position, in.position.w > 0.5);\n"
+"    let cp = u.mvp * pos;\n"
+"    // GL [-w, w] → WebGPU [0, w] clip-z remap, matching every other pipeline.\n"
+"    out.clip_pos = vec4<f32>(cp.x, cp.y, (cp.z + cp.w) * 0.5, cp.w);\n"
+"    return out;\n"
