+			// leaves the texture unallocated -> "offset overflows texture dimensions" on the
+			// CopyTexSubImage2D below). RGBA also matches the framebuffer for the copy.
+			qglTexImage2D( GL_TEXTURE_2D, 0, GL_RGBA, potWidth, potHeight, 0, GL_RGBA, GL_UNSIGNED_BYTE, junk );
 			Mem_Free( junk );
 
 			qglCopyTexSubImage2D( GL_TEXTURE_2D, 0, 0, 0, x, y, imageWidth, imageHeight );
