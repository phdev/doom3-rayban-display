+    WGPUBindGroupLayout     skyBGL = nullptr;
+    WGPUBuffer              skyDirBuf = nullptr;
+    uint32_t                skyDirCap = 0;
+    WGPUBuffer              skyUniformBufs[16] = {nullptr};
+    WGPUBindGroup           skyBindGroups[16]  = {nullptr};
