+                dss.stencilBack.depthFailOp  = WGPUStencilOperation_DecrementWrap;
+                dss.stencilFront.passOp = dss.stencilBack.passOp = WGPUStencilOperation_Keep;
+            } else {
+                dss.stencilFront.depthFailOp = dss.stencilBack.depthFailOp = WGPUStencilOperation_Keep;
+                dss.stencilFront.passOp = WGPUStencilOperation_DecrementWrap;
+                dss.stencilBack.passOp  = WGPUStencilOperation_IncrementWrap;
+            }
+            // Color target declared (writeMask none) for pass compatibility —
+            // the per-light pass has a color attachment.
+            WGPUColorTargetState target = {};
+            target.format = surfaceFormat;
+            target.writeMask = WGPUColorWriteMask_None;
+            WGPUFragmentState frag = {};
+            frag.module = mod;
+            frag.entryPoint = { "fs_main", WGPU_STRLEN };
+            frag.targetCount = 1;
+            frag.targets = &target;
+            WGPURenderPipelineDescriptor pd = {};
+            pd.label = { label, WGPU_STRLEN };
+            pd.layout = pl;
+            pd.vertex.module = mod;
+            pd.vertex.entryPoint = { "vs_main", WGPU_STRLEN };
+            pd.vertex.bufferCount = 1;
