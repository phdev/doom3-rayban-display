new file mode 100644
index 0000000..2e7755b
--- /dev/null
+++ b/neo/sys/wasm/d3_runtime_exports.js
@@ -0,0 +1,28 @@
+// Meta Ray-Ban Display: re-expose Emscripten runtime helpers on Module so the
+// web app shell (src/d3Runtime.js) can install PK4 data and call main itself.
+(function () {
+	if (typeof callMain === "function") {
+		Module["callMain"] = callMain;
+	}
+	if (typeof ccall === "function") {
+		Module["ccall"] = ccall;
+	}
+	if (typeof cwrap === "function") {
+		Module["cwrap"] = cwrap;
+	}
+	if (typeof FS === "object") {
+		Module["FS"] = FS;
+	}
+	if (typeof FS_createPath === "function") {
+		Module["FS_createPath"] = FS_createPath;
+	}
+	if (typeof FS_createDataFile === "function") {
+		Module["FS_createDataFile"] = FS_createDataFile;
+	}
+	if (typeof addRunDependency === "function") {
+		Module["addRunDependency"] = addRunDependency;
+	}
+	if (typeof removeRunDependency === "function") {
+		Module["removeRunDependency"] = removeRunDependency;
+	}
+}());
