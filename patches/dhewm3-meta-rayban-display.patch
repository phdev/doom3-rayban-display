+    static void detMapCallback(WGPUMapAsyncStatus status, WGPUStringView /*msg*/, void* ud1, void* /*ud2*/) {
+        idRenderBackend_WebGPU* self = (idRenderBackend_WebGPU*)ud1;
+        if (status != WGPUMapAsyncStatus_Success) self->detMapFailed = true;
+        if (--self->detMapsPending > 0) return;
+
+        // Both buffers settled — compare (skip row padding bytes).
+        if (self->detMapFailed) {
+            EM_ASM({ console.warn("[d3] WebGPU det self-test: buffer map FAILED — round skipped"); });
+        } else {
+            const int w = self->depthW, h = self->depthH;
+            const uint32_t bpr = self->detBytesPerRow;
+            const size_t total = (size_t)bpr * (size_t)h;
+            const uint8_t* a = (const uint8_t*)wgpuBufferGetConstMappedRange(self->detBufA, 0, total);
+            const uint8_t* b = (const uint8_t*)wgpuBufferGetConstMappedRange(self->detBufB, 0, total);
+            uint32_t diffPx = 0; int maxDelta = 0;
+            if (a && b) {
+                for (int y = 0; y < h; ++y) {
+                    const uint8_t* ra = a + (size_t)y * bpr;
+                    const uint8_t* rb = b + (size_t)y * bpr;
+                    for (int x = 0; x < w * 4; x += 4) {
+                        int d0 = ra[x]-rb[x]; if (d0 < 0) d0 = -d0;
+                        int d1 = ra[x+1]-rb[x+1]; if (d1 < 0) d1 = -d1;
+                        int d2 = ra[x+2]-rb[x+2]; if (d2 < 0) d2 = -d2;
+                        int d = d0 > d1 ? d0 : d1; if (d2 > d) d = d2;
+                        if (d > 0) { diffPx++; if (d > maxDelta) maxDelta = d; }
+                    }
+                }
+                EM_ASM_({
+                    var pct = ($0 / ($2 * $3) * 100).toFixed(4);
+                    console.info("[d3] WebGPU DETERMINISM round " + $4 + ": " +
+                        ($0 === 0 ? "IDENTICAL" : ($0 + " px differ (" + pct + "%), maxDelta=" + $1)) +
+                        " [" + $2 + "x" + $3 + ", " + $5 + " surfaces]");
+                    window.__d3WgpuDet = window.__d3WgpuDet || [];
+                    window.__d3WgpuDet.push({ round: $4, diffPx: $0, maxDelta: $1, w: $2, h: $3, surfaces: $5 });
+                }, diffPx, maxDelta, w, h, (int)self->detRoundsDone + 1, (int)self->lastRecordCount);
+            } else {
+                EM_ASM({ console.warn("[d3] WebGPU det self-test: mapped range null — round skipped"); });
+            }
+        }
+        wgpuBufferUnmap(self->detBufA);
+        wgpuBufferUnmap(self->detBufB);
+        self->detRoundsDone++;
+        self->detMapFailed = false;
+        // detMapsPending == 0 → idle; next round arms on the frame cadence.
+    }
+
+    // Run one self-test round: two identical passes → two readback buffers
+    // → async compare. Called from EndFrame on a frame cadence.
+    void runDeterminismRound() {
+        const int w = depthW, h = depthH;
+        if (w <= 0 || h <= 0) return;
+        if (!detTexA) {
+            WGPUTextureDescriptor td = {};
+            td.size = { (uint32_t)w, (uint32_t)h, 1 };
+            td.mipLevelCount = 1;
+            td.sampleCount = 1;
+            td.dimension = WGPUTextureDimension_2D;
+            td.format = surfaceFormat;   // must match interactionPipeline target
+            td.usage = WGPUTextureUsage_RenderAttachment | WGPUTextureUsage_CopySrc;
+            detTexA = wgpuDeviceCreateTexture(device, &td);
+            detTexB = wgpuDeviceCreateTexture(device, &td);
+            WGPUTextureDescriptor dd = td;
+            dd.format = WGPUTextureFormat_Depth24PlusStencil8;
+            dd.usage = WGPUTextureUsage_RenderAttachment;
+            detDepthTex = wgpuDeviceCreateTexture(device, &dd);
+            detViewA = detTexA ? wgpuTextureCreateView(detTexA, nullptr) : nullptr;
+            detViewB = detTexB ? wgpuTextureCreateView(detTexB, nullptr) : nullptr;
+            detDepthView = detDepthTex ? wgpuTextureCreateView(detDepthTex, nullptr) : nullptr;
+            detBytesPerRow = ((uint32_t)w * 4u + 255u) & ~255u;
+            WGPUBufferDescriptor bd = {};
+            bd.size = (uint64_t)detBytesPerRow * (uint64_t)h;
+            bd.usage = WGPUBufferUsage_MapRead | WGPUBufferUsage_CopyDst;
+            detBufA = wgpuDeviceCreateBuffer(device, &bd);
+            detBufB = wgpuDeviceCreateBuffer(device, &bd);
+        }
+        if (!detViewA || !detViewB || !detDepthView || !detBufA || !detBufB) return;
+
+        WGPUCommandEncoderDescriptor cd = {};
+        WGPUCommandEncoder enc = wgpuDeviceCreateCommandEncoder(device, &cd);
+        encodeRecordsPass(enc, detViewA, detDepthView, detTexA);
+        encodeRecordsPass(enc, detViewB, detDepthView, detTexB);
+        WGPUTexelCopyTextureInfo srcA = {}; srcA.texture = detTexA;
+        WGPUTexelCopyTextureInfo srcB = {}; srcB.texture = detTexB;
+        WGPUTexelCopyBufferInfo dstA = {};
+        dstA.layout.bytesPerRow = detBytesPerRow;
+        dstA.layout.rowsPerImage = (uint32_t)h;
+        dstA.buffer = detBufA;
+        WGPUTexelCopyBufferInfo dstB = dstA;
+        dstB.buffer = detBufB;
+        WGPUExtent3D ext = { (uint32_t)w, (uint32_t)h, 1 };
+        wgpuCommandEncoderCopyTextureToBuffer(enc, &srcA, &dstA, &ext);
+        wgpuCommandEncoderCopyTextureToBuffer(enc, &srcB, &dstB, &ext);
+        WGPUCommandBuffer cb = wgpuCommandEncoderFinish(enc, nullptr);
+        wgpuCommandEncoderRelease(enc);
+        wgpuQueueSubmit(queue, 1, &cb);
+        wgpuCommandBufferRelease(cb);
+
+        detMapsPending = 2;
+        detMapFailed = false;
+        WGPUBufferMapCallbackInfo cbi = {};
+        cbi.mode = WGPUCallbackMode_AllowSpontaneous;
+        cbi.callback = &idRenderBackend_WebGPU::detMapCallback;
+        cbi.userdata1 = this;
+        wgpuBufferMapAsync(detBufA, WGPUMapMode_Read, 0, (size_t)detBytesPerRow * (size_t)depthH, cbi);
+        wgpuBufferMapAsync(detBufB, WGPUMapMode_Read, 0, (size_t)detBytesPerRow * (size_t)depthH, cbi);
+    }
+#endif
+
+    void BeginRenderPass(const idGpuRenderPassDesc& desc) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!cmdEncoder) return;
+        if (renderPass) {
+            // The engine called BeginRenderPass twice without EndRenderPass —
+            // close the previous one to avoid leaking state.
+            wgpuRenderPassEncoderEnd(renderPass);
+            wgpuRenderPassEncoderRelease(renderPass);
+            renderPass = nullptr;
+        }
+
+        // Color attachment. id 0 means "default backbuffer / surface", which
+        // we don't have a swapchain for yet (Phase 5c). Defensive: silently
+        // skip if no target — the migration is incremental.
+        if (!desc.colorAttachment.id) return;
+
+        WGPUTextureView colorView = wgpuTextureCreateView((WGPUTexture)desc.colorAttachment.id, nullptr);
+
+        WGPURenderPassColorAttachment colorAttach = {};
+        colorAttach.view = colorView;
+        colorAttach.loadOp = (desc.colorLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear
+                            : (desc.colorLoad == idGpuLoadOp::Load)  ? WGPULoadOp_Load
+                            : WGPULoadOp_Undefined;
+        colorAttach.storeOp = (desc.colorStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+        colorAttach.clearValue = { desc.clearR, desc.clearG, desc.clearB, desc.clearA };
+        colorAttach.depthSlice = WGPU_DEPTH_SLICE_UNDEFINED;
+
+        WGPURenderPassDepthStencilAttachment depthAttach = {};
+        WGPUTextureView depthView = nullptr;
+        if (desc.hasDepth && desc.depthAttachment.id) {
+            depthView = wgpuTextureCreateView((WGPUTexture)desc.depthAttachment.id, nullptr);
+            depthAttach.view = depthView;
+            depthAttach.depthLoadOp = (desc.depthLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear : WGPULoadOp_Load;
+            depthAttach.depthStoreOp = (desc.depthStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+            depthAttach.depthClearValue = desc.clearDepth;
+            depthAttach.stencilLoadOp = (desc.stencilLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear : WGPULoadOp_Load;
+            depthAttach.stencilStoreOp = (desc.stencilStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+            depthAttach.stencilClearValue = desc.clearStencil;
+        }
+
+        WGPURenderPassDescriptor rpd = {};
+        if (desc.name) rpd.label = { desc.name, WGPU_STRLEN };
+        rpd.colorAttachmentCount = 1;
+        rpd.colorAttachments = &colorAttach;
+        rpd.depthStencilAttachment = depthView ? &depthAttach : nullptr;
+
+        renderPass = wgpuCommandEncoderBeginRenderPass(cmdEncoder, &rpd);
+        wgpuTextureViewRelease(colorView);
+        if (depthView) wgpuTextureViewRelease(depthView);
+#else
+        (void)desc;
+#endif
+    }
+
+    void EndRenderPass() override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass) return;
+        wgpuRenderPassEncoderEnd(renderPass);
+        wgpuRenderPassEncoderRelease(renderPass);
+        renderPass = nullptr;
+#endif
+    }
