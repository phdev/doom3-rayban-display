+// are cached, the rest fall through to procedural textures. RAM cost cap:
+// 512 * 128 * 128 * 4 = 32MB worst case (image_downSizeLimit=128 enforced).
+struct WGPUImageSlot {
+    const void* ptr;        // idImage* (opaque void* to avoid the include)
+    int         w, h;
+    uint8_t*    pixels;     // malloc'd RGBA8 buffer, owned
+};
+extern "C" {
+    enum { kWGPUImageCacheSize = 512 };
+    WGPUImageSlot g_imgCache[kWGPUImageCacheSize] = {};
+    int g_imgCacheCount = 0;
+}
+
+
+extern "C" void D3_WebGPU_CacheImage( const class idImage* img, const unsigned char* rgba, int w, int h ) {
+    if ( !img || !rgba || w <= 0 || h <= 0 || w > 1024 || h > 1024 ) return;
+    // Find existing slot or allocate
+    int slot = -1;
+    for ( int i = 0; i < g_imgCacheCount; ++i ) {
+        if ( g_imgCache[i].ptr == (const void*)img ) { slot = i; break; }
+    }
+    if ( slot < 0 ) {
+        if ( g_imgCacheCount >= kWGPUImageCacheSize ) return;
+        slot = g_imgCacheCount++;
+        g_imgCache[slot].ptr = (const void*)img;
+        g_imgCache[slot].pixels = nullptr;
+    }
+    // Reallocate if size changed (e.g. reloaded at different mip level)
+    const size_t bytes = (size_t)w * (size_t)h * 4u;
+    if ( !g_imgCache[slot].pixels || g_imgCache[slot].w != w || g_imgCache[slot].h != h ) {
+        free( g_imgCache[slot].pixels );
+        g_imgCache[slot].pixels = (uint8_t*)malloc( bytes );
+        if ( !g_imgCache[slot].pixels ) { g_imgCache[slot].ptr = nullptr; return; }
+        g_imgCache[slot].w = w;
+        g_imgCache[slot].h = h;
+    }
+    memcpy( g_imgCache[slot].pixels, rgba, bytes );
+}
+
+extern "C" const WGPUImageSlot* D3_WebGPU_LookupCachedImage( const void* img ) {
+    if ( !img ) return nullptr;
+    for ( int i = 0; i < g_imgCacheCount; ++i ) {
+        if ( g_imgCache[i].ptr == img ) return &g_imgCache[i];
+    }
+    return nullptr;
+}
