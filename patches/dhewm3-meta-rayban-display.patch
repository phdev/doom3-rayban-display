+                subGroups[L].count = n - start;
+                if (n > start) subGroupCount = L + 1;
+            }
+        }
+        // Per-slot uniform writes. r.modelMatrix holds the FULL MVP, baked
+        // at capture time in draw_arb2.cpp where this view's projection and
+        // this surface's modelView are both in scope. Use verbatim.
+        extern float g_capInvGamma;
+        for (uint32_t i = 0; i < n; ++i) {
+            const Rec& r = g_capRecords[i];
+            float ub[56];
+            memcpy(ub +  0, r.modelMatrix, 64);
+            memcpy(ub + 16, r.localLightOrigin, 16);
+            memcpy(ub + 20, r.localViewOrigin,  16);
+            memcpy(ub + 24, r.diffuseColor,     16);
+            memcpy(ub + 28, r.specularColor,    16);
+            memcpy(ub + 32, r.lightProjS,       16);
+            memcpy(ub + 36, r.lightProjT,       16);
+            memcpy(ub + 40, r.lightProjQ,       16);
+            memcpy(ub + 44, r.lightFalloffS,    16);
