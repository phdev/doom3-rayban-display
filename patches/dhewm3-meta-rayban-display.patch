+
+        // Iter 9: drain shadow records — upload the vec4 vertex accumulator,
+        // filter to the main view, write per-slot mvp + light uniforms.
+        {
+            extern Rec      g_shadowRecords[];
+            extern uint8_t  g_shadowVertsAccum[];
+            extern uint32_t g_shadowVertBytes;
+            extern uint32_t g_shadowRecordCount;
+            uint32_t sn = 0;
