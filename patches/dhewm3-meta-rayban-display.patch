+    // render into 256px offscreen targets BEFORE the main passes; samples of
+    // the linked engine image are overridden with the target's view.
+    static constexpr uint32_t kMaxSubviews = 2;
+    WGPUTexture             subviewTex[kMaxSubviews] = {nullptr};
+    WGPUTextureView         subviewView[kMaxSubviews] = {nullptr};
+    WGPUTexture             subviewDepthTex[kMaxSubviews] = {nullptr};
+    WGPUTextureView         subviewDepthView[kMaxSubviews] = {nullptr};
+    struct SubGroup { uint32_t startSlot, count; };
+    SubGroup                subGroups[kMaxSubviews] = {};
+    uint32_t                subGroupCount = 0;
+    // Iter 15b: reflect-cube records (chrome/env-mapped surfaces).
+    WGPURenderPipeline      reflectPipeline = nullptr;
+    WGPUBindGroupLayout     reflectBGL = nullptr;
+    WGPUBuffer              reflectUniformBufs[8] = {nullptr};
+    WGPUBindGroup           reflectBindGroups[8]  = {nullptr};
+    const void*             reflectGroupImg[8] = {};
+    Rec                     lastReflectRecords[8] = {};
+    uint32_t                lastReflectCount = 0;
+    // Iter 16: heat-haze new stages. The final pass splits in two around a
+    // canvas→currentRenderTex copy; haze draws sample the copy, deflected
+    // by a scrolled normal map (heatHaze*.vfp semantics in haze.wgsl).
+    WGPURenderPipeline      hazePipeline = nullptr;
+    WGPUBindGroupLayout     hazeBGL = nullptr;
+    WGPUBuffer              hazeVertexBuf = nullptr;
+    WGPUBuffer              hazeIndexBuf = nullptr;
+    uint32_t                hazeVertexCap = 0;
+    uint32_t                hazeIndexCap = 0;
+    WGPUBuffer              hazeUniformBufs[16] = {nullptr};
+    WGPUBindGroup           hazeBindGroups[16]  = {nullptr};
+    const void*             hazeGroupImgs[16][2] = {};
+    uint32_t                hazeGroupGen[16] = {};
+    Rec                     lastHazeRecords[16] = {};
+    uint32_t                lastHazeCount = 0;
+    WGPUTexture             currentRenderTex = nullptr;
+    WGPUTextureView         currentRenderView = nullptr;
+    uint32_t                currentRenderW = 0, currentRenderH = 0;
+    uint32_t                currentRenderGen = 0;   // bumps on recreate → bind groups rebuild
+    // Iter 17: per-slot dynamic textures for decoded cinematic (ROQ) frames.
+    static constexpr uint32_t kCinSlots = 4;
+    WGPUTexture             cinTex[kCinSlots] = {nullptr};
+    WGPUTextureView         cinView[kCinSlots] = {nullptr};
+    int                     cinTexW[kCinSlots] = {0};
+    int                     cinTexH[kCinSlots] = {0};
+    WGPUBindGroup           cinFrameGroups[kCinSlots] = {nullptr};   // transient, per frame
+    // Iter 19: bloom — quarter-res bright-pass + separable blur + additive
+    // composite over the canvas. Tunables ride g_capBloom* (cvar exports).
+    WGPUBindGroupLayout     bloomBGL = nullptr;
+    WGPURenderPipeline      bloomBrightPipeline = nullptr;
+    WGPURenderPipeline      bloomBlurPipeline = nullptr;
+    WGPURenderPipeline      bloomCompositePipeline = nullptr;
