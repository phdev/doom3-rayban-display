+    void UpdateBuffer(idGpuBuffer buf, size_t offset, size_t bytes, const void* data) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!buf.id) return;
+        wgpuQueueWriteBuffer(queue, (WGPUBuffer)buf.id, (uint64_t)offset, data, bytes);
+#else
+        (void)buf; (void)offset; (void)bytes; (void)data;
+#endif
+    }
+
