@@ -0,0 +1,632 @@
+/*
+================================================================================
+
+RenderBackend_WebGPU.cpp — WebGPU backend (Phase 5 partial).
+
+STATUS
+------
+Phase 5 partial: Init() picks up the JS-preinitialized device. Buffer /
+Texture / Sampler resource ops implemented against the real Dawn C API.
+Pipeline / BindGroup / RenderPass / Draw still stubbed (the remaining
+~70% of Phase 5).
+
+Build: requires --use-port=emdawnwebgpu (set in scripts/build-dhewm3.sh)
+and -DD3_WEBGPU_BACKEND=1 (also set).
+
+ID SCHEME
+---------
+Backend resource handles (idGpuBuffer etc.) store the raw WGPU object
+pointer cast to uint64_t. Avoids a separate handle table; works because
+emscripten's pointer width fits in 64 bits. Zero id == null/invalid.
+
+================================================================================
+*/
+
+#include "RenderBackend.h"
+
+#if defined(D3_WEBGPU_BACKEND) && defined(__EMSCRIPTEN__)
+#include <emscripten.h>
+// emdawnwebgpu exposes emscripten_webgpu_get_device() directly from webgpu.h
+// (no separate html5_webgpu.h header any more — that was removed in the
+// transition away from -sUSE_WEBGPU=1).
+#include <webgpu/webgpu.h>
+#define D3_WEBGPU_AVAILABLE 1
+#else
+#define D3_WEBGPU_AVAILABLE 0
+#endif
+
+#include <cassert>
+#include <cstdio>
+#include <cstring>
+
+#define WGPU_NOT_YET(name) do { \
+    static bool warned = false; \
+    if (!warned) { fprintf(stderr, "[WebGPU stub] %s not implemented\n", name); warned = true; } \
+} while (0)
+
+#if D3_WEBGPU_AVAILABLE
+
+// ─── Format / usage mapping helpers ─────────────────────────────────────────
+
+static WGPUTextureFormat toWGPUFormat(idGpuTextureFormat f) {
+    switch (f) {
+        case idGpuTextureFormat::R8:               return WGPUTextureFormat_R8Unorm;
+        case idGpuTextureFormat::RG8:              return WGPUTextureFormat_RG8Unorm;
+        case idGpuTextureFormat::RGBA8:            return WGPUTextureFormat_RGBA8Unorm;
+        case idGpuTextureFormat::RGBA8Srgb:        return WGPUTextureFormat_RGBA8UnormSrgb;
+        case idGpuTextureFormat::RGB10A2:          return WGPUTextureFormat_RGB10A2Unorm;
+        case idGpuTextureFormat::R11G11B10F:       return WGPUTextureFormat_RG11B10Ufloat;
+        case idGpuTextureFormat::R16F:             return WGPUTextureFormat_R16Float;
+        case idGpuTextureFormat::RGBA16F:          return WGPUTextureFormat_RGBA16Float;
+        case idGpuTextureFormat::R32F:             return WGPUTextureFormat_R32Float;
+        case idGpuTextureFormat::Depth16:          return WGPUTextureFormat_Depth16Unorm;
+        case idGpuTextureFormat::Depth24:          return WGPUTextureFormat_Depth24Plus;
+        case idGpuTextureFormat::Depth24Stencil8:  return WGPUTextureFormat_Depth24PlusStencil8;
+        case idGpuTextureFormat::Depth32F:         return WGPUTextureFormat_Depth32Float;
+        case idGpuTextureFormat::BC1:              return WGPUTextureFormat_BC1RGBAUnorm;
+        case idGpuTextureFormat::BC3:              return WGPUTextureFormat_BC3RGBAUnorm;
+        case idGpuTextureFormat::BC7:              return WGPUTextureFormat_BC7RGBAUnorm;
+        case idGpuTextureFormat::ASTC4x4:          return WGPUTextureFormat_ASTC4x4Unorm;
+        default:                                   return WGPUTextureFormat_Undefined;
+    }
+}
+
+static WGPUBufferUsage toWGPUBufferUsage(uint32_t usage) {
+    uint32_t out = 0;
+    if (usage & (uint32_t)idGpuBufferUsage::Vertex)    out |= WGPUBufferUsage_Vertex;
+    if (usage & (uint32_t)idGpuBufferUsage::Index)     out |= WGPUBufferUsage_Index;
+    if (usage & (uint32_t)idGpuBufferUsage::Uniform)   out |= WGPUBufferUsage_Uniform;
+    if (usage & (uint32_t)idGpuBufferUsage::Storage)   out |= WGPUBufferUsage_Storage;
+    if (usage & (uint32_t)idGpuBufferUsage::CopySrc)   out |= WGPUBufferUsage_CopySrc;
+    if (usage & (uint32_t)idGpuBufferUsage::CopyDst)   out |= WGPUBufferUsage_CopyDst;
+    if (usage & (uint32_t)idGpuBufferUsage::MapWrite)  out |= WGPUBufferUsage_MapWrite;
+    if (usage & (uint32_t)idGpuBufferUsage::MapRead)   out |= WGPUBufferUsage_MapRead;
+    return (WGPUBufferUsage)out;
+}
+
+static WGPUTextureUsage toWGPUTextureUsage(uint32_t usage) {
+    uint32_t out = 0;
+    if (usage & (uint32_t)idGpuTextureUsage::Sampled)      out |= WGPUTextureUsage_TextureBinding;
+    if (usage & (uint32_t)idGpuTextureUsage::Storage)      out |= WGPUTextureUsage_StorageBinding;
+    if (usage & (uint32_t)idGpuTextureUsage::RenderTarget) out |= WGPUTextureUsage_RenderAttachment;
+    if (usage & (uint32_t)idGpuTextureUsage::CopySrc)      out |= WGPUTextureUsage_CopySrc;
+    if (usage & (uint32_t)idGpuTextureUsage::CopyDst)      out |= WGPUTextureUsage_CopyDst;
+    return (WGPUTextureUsage)out;
+}
+
+#endif // D3_WEBGPU_AVAILABLE
+
+// ─── Backend class ──────────────────────────────────────────────────────────
+
+class idRenderBackend_WebGPU : public idRenderBackend {
+public:
+    idGpuBackendKind GetKind() const override { return idGpuBackendKind::WebGPU; }
+
+    bool Init(void* /*nativeWindow*/, int /*w*/, int /*h*/) override {
+#if D3_WEBGPU_AVAILABLE
+        // The JS shell pre-acquires the WGPUDevice and stashes it in
+        // Module.preinitializedWebGPUDevice (see src/d3Runtime.js). The
+        // Emscripten WebGPU port exposes it synchronously here.
+        device = emscripten_webgpu_get_device();
+        if (!device) {
+            fprintf(stderr, "[WebGPU] emscripten_webgpu_get_device returned null. "
+                            "JS pre-acquire likely failed (no navigator.gpu or "
+                            "device request rejected).\n");
+            return false;
+        }
+        queue = wgpuDeviceGetQueue(device);
+        fprintf(stderr, "[WebGPU] device + queue acquired\n");
+        return true;
+#else
+        fprintf(stderr, "[WebGPU] not compiled in (D3_WEBGPU_BACKEND not set)\n");
+        return false;
+#endif
+    }
+
+    void Shutdown() override {
+#if D3_WEBGPU_AVAILABLE
+        if (queue)  { wgpuQueueRelease(queue);   queue = nullptr; }
+        if (device) { wgpuDeviceRelease(device); device = nullptr; }
+#endif
+    }
+
+    void Resize(int /*w*/, int /*h*/) override {
+        // Surface reconfiguration goes here in Phase 5b.
+    }
+
+    // ─── Frame / render pass — IMPLEMENTED (Phase 5b) ───────────────────────
+
+    void BeginFrame() override {
+#if D3_WEBGPU_AVAILABLE
+        if (!device) return;
+        if (cmdEncoder) {
+            // Stale encoder from a previous frame that wasn't submitted.
+            // Drop it; the engine will re-record this frame fresh.
+            wgpuCommandEncoderRelease(cmdEncoder);
+            cmdEncoder = nullptr;
+        }
+        WGPUCommandEncoderDescriptor cd = {};
+        cd.label = { "frame", WGPU_STRLEN };
+        cmdEncoder = wgpuDeviceCreateCommandEncoder(device, &cd);
+#endif
+    }
+
+    void EndFrame() override {
+#if D3_WEBGPU_AVAILABLE
+        if (!cmdEncoder) return;
+        WGPUCommandBufferDescriptor cbd = {};
+        cbd.label = { "frame", WGPU_STRLEN };
+        WGPUCommandBuffer cb = wgpuCommandEncoderFinish(cmdEncoder, &cbd);
+        wgpuCommandEncoderRelease(cmdEncoder);
+        cmdEncoder = nullptr;
+        wgpuQueueSubmit(queue, 1, &cb);
+        wgpuCommandBufferRelease(cb);
+#endif
+    }
+
+    void BeginRenderPass(const idGpuRenderPassDesc& desc) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!cmdEncoder) return;
+        if (renderPass) {
+            // The engine called BeginRenderPass twice without EndRenderPass —
+            // close the previous one to avoid leaking state.
+            wgpuRenderPassEncoderEnd(renderPass);
+            wgpuRenderPassEncoderRelease(renderPass);
+            renderPass = nullptr;
+        }
+
+        // Color attachment. id 0 means "default backbuffer / surface", which
+        // we don't have a swapchain for yet (Phase 5c). Defensive: silently
+        // skip if no target — the migration is incremental.
+        if (!desc.colorAttachment.id) return;
+
+        WGPUTextureView colorView = wgpuTextureCreateView((WGPUTexture)desc.colorAttachment.id, nullptr);
+
+        WGPURenderPassColorAttachment colorAttach = {};
+        colorAttach.view = colorView;
+        colorAttach.loadOp = (desc.colorLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear
+                            : (desc.colorLoad == idGpuLoadOp::Load)  ? WGPULoadOp_Load
+                            : WGPULoadOp_Undefined;
+        colorAttach.storeOp = (desc.colorStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+        colorAttach.clearValue = { desc.clearR, desc.clearG, desc.clearB, desc.clearA };
+        colorAttach.depthSlice = WGPU_DEPTH_SLICE_UNDEFINED;
+
+        WGPURenderPassDepthStencilAttachment depthAttach = {};
+        WGPUTextureView depthView = nullptr;
+        if (desc.hasDepth && desc.depthAttachment.id) {
+            depthView = wgpuTextureCreateView((WGPUTexture)desc.depthAttachment.id, nullptr);
+            depthAttach.view = depthView;
+            depthAttach.depthLoadOp = (desc.depthLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear : WGPULoadOp_Load;
+            depthAttach.depthStoreOp = (desc.depthStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+            depthAttach.depthClearValue = desc.clearDepth;
+            depthAttach.stencilLoadOp = (desc.stencilLoad == idGpuLoadOp::Clear) ? WGPULoadOp_Clear : WGPULoadOp_Load;
+            depthAttach.stencilStoreOp = (desc.stencilStore == idGpuStoreOp::Store) ? WGPUStoreOp_Store : WGPUStoreOp_Discard;
+            depthAttach.stencilClearValue = desc.clearStencil;
+        }
+
+        WGPURenderPassDescriptor rpd = {};
+        if (desc.name) rpd.label = { desc.name, WGPU_STRLEN };
+        rpd.colorAttachmentCount = 1;
+        rpd.colorAttachments = &colorAttach;
+        rpd.depthStencilAttachment = depthView ? &depthAttach : nullptr;
+
+        renderPass = wgpuCommandEncoderBeginRenderPass(cmdEncoder, &rpd);
+        wgpuTextureViewRelease(colorView);
+        if (depthView) wgpuTextureViewRelease(depthView);
+#else
+        (void)desc;
+#endif
+    }
+
+    void EndRenderPass() override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass) return;
+        wgpuRenderPassEncoderEnd(renderPass);
+        wgpuRenderPassEncoderRelease(renderPass);
+        renderPass = nullptr;
+#endif
+    }
+
+    // ─── Pipeline / bind group — IMPLEMENTED (Phase 5c) ─────────────────────
+
+    idGpuPipeline CreatePipeline(const idGpuPipelineDesc& desc) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!device || !desc.wgsl) return {};
+
+        // Shader module
+        WGPUShaderSourceWGSL wgsl = {};
+        wgsl.chain.sType = WGPUSType_ShaderSourceWGSL;
+        wgsl.code = { desc.wgsl, WGPU_STRLEN };
+        WGPUShaderModuleDescriptor smd = {};
+        smd.nextInChain = &wgsl.chain;
+        if (desc.name) smd.label = { desc.name, WGPU_STRLEN };
+        WGPUShaderModule module = wgpuDeviceCreateShaderModule(device, &smd);
+        if (!module) return {};
+
+        // Vertex layout: assume idDrawVert (the engine's primary vertex
+        // struct: 60 bytes — xyz / st / normal / tangents[2] / color).
+        // Variants can come later by switching desc, but most of dhewm3 uses
+        // this single layout.
+        static const WGPUVertexAttribute kIdDrawVertAttrs[] = {
+            { nullptr, WGPUVertexFormat_Float32x3, 0,  0 },  // xyz       (loc 0)
+            { nullptr, WGPUVertexFormat_Float32x2, 12, 1 },  // st        (loc 1)
+            { nullptr, WGPUVertexFormat_Float32x3, 20, 2 },  // normal    (loc 2)
+            { nullptr, WGPUVertexFormat_Float32x3, 32, 3 },  // tangent   (loc 3)
+            { nullptr, WGPUVertexFormat_Float32x3, 44, 4 },  // bitangent (loc 4)
+            { nullptr, WGPUVertexFormat_Unorm8x4,  56, 5 },  // color     (loc 5)
+        };
+        WGPUVertexBufferLayout vbl = {};
+        vbl.stepMode = WGPUVertexStepMode_Vertex;
+        vbl.arrayStride = 60;
+        vbl.attributeCount = sizeof(kIdDrawVertAttrs) / sizeof(kIdDrawVertAttrs[0]);
+        vbl.attributes = kIdDrawVertAttrs;
+
+        // Color target + blend state
+        WGPUColorTargetState target = {};
+        WGPUBlendState blend = {};
+        if (desc.hasColorTarget) {
+            target.format = toWGPUFormat(desc.color.format);
+            target.writeMask = desc.color.writeMask;
+            if (desc.color.blendEnabled) {
+                blend.color.srcFactor = (WGPUBlendFactor)desc.color.srcColor;
+                blend.color.dstFactor = (WGPUBlendFactor)desc.color.dstColor;
+                blend.color.operation = (WGPUBlendOperation)desc.color.colorOp;
+                blend.alpha.srcFactor = (WGPUBlendFactor)desc.color.srcAlpha;
+                blend.alpha.dstFactor = (WGPUBlendFactor)desc.color.dstAlpha;
+                blend.alpha.operation = (WGPUBlendOperation)desc.color.alphaOp;
+                target.blend = &blend;
+            }
+        }
+
+        // Depth-stencil
+        WGPUDepthStencilState ds = {};
+        if (desc.hasDepthStencil) {
+            ds.format = toWGPUFormat(desc.depthStencil.format);
+            ds.depthWriteEnabled = desc.depthStencil.depthWriteEnabled ? WGPUOptionalBool_True : WGPUOptionalBool_False;
+            ds.depthCompare = (WGPUCompareFunction)desc.depthStencil.depthCompare;
+            ds.stencilFront.compare = (WGPUCompareFunction)desc.depthStencil.stencilFrontCompare;
+            ds.stencilFront.failOp = (WGPUStencilOperation)desc.depthStencil.stencilFrontFail;
+            ds.stencilFront.depthFailOp = (WGPUStencilOperation)desc.depthStencil.stencilFrontDepthFail;
+            ds.stencilFront.passOp = (WGPUStencilOperation)desc.depthStencil.stencilFrontPass;
+            ds.stencilBack.compare = (WGPUCompareFunction)desc.depthStencil.stencilBackCompare;
+            ds.stencilBack.failOp = (WGPUStencilOperation)desc.depthStencil.stencilBackFail;
+            ds.stencilBack.depthFailOp = (WGPUStencilOperation)desc.depthStencil.stencilBackDepthFail;
+            ds.stencilBack.passOp = (WGPUStencilOperation)desc.depthStencil.stencilBackPass;
+            ds.stencilReadMask = desc.depthStencil.stencilReadMask;
+            ds.stencilWriteMask = desc.depthStencil.stencilWriteMask;
+        }
+
+        // Fragment state
+        WGPUFragmentState frag = {};
+        frag.module = module;
+        frag.entryPoint = { desc.fsEntryPoint ? desc.fsEntryPoint : "fs_main", WGPU_STRLEN };
+        frag.targetCount = desc.hasColorTarget ? 1 : 0;
+        frag.targets = desc.hasColorTarget ? &target : nullptr;
+
+        WGPURenderPipelineDescriptor pd = {};
+        if (desc.name) pd.label = { desc.name, WGPU_STRLEN };
+        pd.layout = nullptr;  // auto layout — bind group layouts derived from WGSL
+        pd.vertex.module = module;
+        pd.vertex.entryPoint = { desc.vsEntryPoint ? desc.vsEntryPoint : "vs_main", WGPU_STRLEN };
+        pd.vertex.bufferCount = 1;
+        pd.vertex.buffers = &vbl;
+        pd.primitive.topology = WGPUPrimitiveTopology_TriangleList;
+        pd.primitive.cullMode = (WGPUCullMode)desc.cull;
+        pd.primitive.frontFace = (desc.frontFace == idGpuFrontFace::CCW)
+                                   ? WGPUFrontFace_CCW : WGPUFrontFace_CW;
+        pd.depthStencil = desc.hasDepthStencil ? &ds : nullptr;
+        pd.multisample.count = 1;
+        pd.multisample.mask = 0xFFFFFFFF;
+        pd.fragment = &frag;
+
+        WGPURenderPipeline pipeline = wgpuDeviceCreateRenderPipeline(device, &pd);
+        wgpuShaderModuleRelease(module);
+        return { (uint64_t)pipeline };
+#else
+        (void)desc;
+        return {};
+#endif
+    }
+
+    void DestroyPipeline(idGpuPipeline p) override {
+#if D3_WEBGPU_AVAILABLE
+        if (p.id) wgpuRenderPipelineRelease((WGPURenderPipeline)p.id);
+#else
+        (void)p;
+#endif
+    }
+
+    void BindPipeline(idGpuPipeline p) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass || !p.id) return;
+        currentPipeline = (WGPURenderPipeline)p.id;
+        wgpuRenderPassEncoderSetPipeline(renderPass, currentPipeline);
+#else
+        (void)p;
+#endif
+    }
+
+    idGpuBindGroup CreateBindGroup(idGpuPipeline pipeline,
+                                     const idGpuTexture* textures, int textureCount,
+                                     const idGpuSampler* samplers, int samplerCount,
+                                     const idGpuBuffer* uniforms, int uniformCount) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!device || !pipeline.id) return {};
+        // Auto-derived bind group layout (slot 0)
+        WGPUBindGroupLayout bgl = wgpuRenderPipelineGetBindGroupLayout(
+            (WGPURenderPipeline)pipeline.id, 0);
+
+        // Entries: uniforms first (binding 0..), then samplers, then textures.
+        // This is a convention; can be parameterized per-pipeline later.
+        int total = uniformCount + samplerCount + textureCount;
+        WGPUBindGroupEntry entries[16] = {};   // 16 is generous; idTech 4 uses ≤9
+        int idx = 0;
+        uint32_t binding = 0;
+        for (int i = 0; i < uniformCount; ++i) {
+            entries[idx].binding = binding++;
+            entries[idx].buffer = (WGPUBuffer)uniforms[i].id;
+            entries[idx].offset = 0;
+            entries[idx].size = WGPU_WHOLE_SIZE;
+            idx++;
+        }
+        for (int i = 0; i < samplerCount; ++i) {
+            entries[idx].binding = binding++;
+            entries[idx].sampler = (WGPUSampler)samplers[i].id;
+            idx++;
+        }
+        // Texture views — create them inline; the bind group holds a ref.
+        WGPUTextureView views[16] = {};
+        for (int i = 0; i < textureCount; ++i) {
+            views[i] = wgpuTextureCreateView((WGPUTexture)textures[i].id, nullptr);
+            entries[idx].binding = binding++;
+            entries[idx].textureView = views[i];
+            idx++;
+        }
+
+        WGPUBindGroupDescriptor bgd = {};
+        bgd.layout = bgl;
+        bgd.entryCount = (uint32_t)total;
+        bgd.entries = entries;
+        WGPUBindGroup bg = wgpuDeviceCreateBindGroup(device, &bgd);
+
+        // Bind group keeps refs to views; we release our local handles.
+        for (int i = 0; i < textureCount; ++i) {
+            if (views[i]) wgpuTextureViewRelease(views[i]);
+        }
+        wgpuBindGroupLayoutRelease(bgl);
+        return { (uint64_t)bg };
+#else
+        (void)pipeline; (void)textures; (void)textureCount;
+        (void)samplers; (void)samplerCount; (void)uniforms; (void)uniformCount;
+        return {};
+#endif
+    }
+
+    void DestroyBindGroup(idGpuBindGroup bg) override {
+#if D3_WEBGPU_AVAILABLE
+        if (bg.id) wgpuBindGroupRelease((WGPUBindGroup)bg.id);
+#else
+        (void)bg;
+#endif
+    }
+
+    void BindBindGroup(uint32_t slot, idGpuBindGroup bg) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass || !bg.id) return;
+        wgpuRenderPassEncoderSetBindGroup(renderPass, slot, (WGPUBindGroup)bg.id, 0, nullptr);
+#else
+        (void)slot; (void)bg;
+#endif
+    }
+
+    // ─── Buffer resources — IMPLEMENTED ─────────────────────────────────────
+
+    idGpuBuffer CreateBuffer(size_t bytes, uint32_t usage, const char* label) override {
+#if D3_WEBGPU_AVAILABLE
+        WGPUBufferDescriptor bd = {};
+        bd.size = (uint64_t)bytes;
+        bd.usage = toWGPUBufferUsage(usage);
+        if (label) { bd.label = { label, WGPU_STRLEN }; }
+        WGPUBuffer buf = wgpuDeviceCreateBuffer(device, &bd);
+        return { (uint64_t)buf };
+#else
+        (void)bytes; (void)usage; (void)label;
+        return {};
+#endif
+    }
+
+    void UpdateBuffer(idGpuBuffer buf, size_t offset, size_t bytes, const void* data) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!buf.id) return;
+        wgpuQueueWriteBuffer(queue, (WGPUBuffer)buf.id, (uint64_t)offset, data, bytes);
+#else
+        (void)buf; (void)offset; (void)bytes; (void)data;
+#endif
+    }
+
+    void DestroyBuffer(idGpuBuffer buf) override {
+#if D3_WEBGPU_AVAILABLE
+        if (buf.id) wgpuBufferRelease((WGPUBuffer)buf.id);
+#else
+        (void)buf;
+#endif
+    }
+
+    void BindVertexBuffer(uint32_t slot, idGpuBuffer buf, size_t offset) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass || !buf.id) return;
+        wgpuRenderPassEncoderSetVertexBuffer(renderPass, slot, (WGPUBuffer)buf.id,
+                                              offset, WGPU_WHOLE_SIZE);
+#else
+        (void)slot; (void)buf; (void)offset;
+#endif
+    }
+
+    void BindIndexBuffer(idGpuBuffer buf, size_t offset, bool isUint32) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!renderPass || !buf.id) return;
+        wgpuRenderPassEncoderSetIndexBuffer(renderPass, (WGPUBuffer)buf.id,
+                                             isUint32 ? WGPUIndexFormat_Uint32 : WGPUIndexFormat_Uint16,
+                                             offset, WGPU_WHOLE_SIZE);
+#else
+        (void)buf; (void)offset; (void)isUint32;
+#endif
+    }
+
+    // ─── Texture resources — IMPLEMENTED ────────────────────────────────────
+
+    idGpuTexture CreateTexture(int width, int height, int mipCount,
+                                idGpuTextureFormat format, uint32_t usage,
+                                const char* label) override {
+#if D3_WEBGPU_AVAILABLE
+        WGPUTextureDescriptor td = {};
+        td.size = { (uint32_t)width, (uint32_t)height, 1 };
+        td.mipLevelCount = (uint32_t)mipCount > 0 ? (uint32_t)mipCount : 1;
+        td.sampleCount = 1;
+        td.dimension = WGPUTextureDimension_2D;
+        td.format = toWGPUFormat(format);
+        td.usage = toWGPUTextureUsage(usage);
+        if (label) { td.label = { label, WGPU_STRLEN }; }
+        WGPUTexture tex = wgpuDeviceCreateTexture(device, &td);
+        return { (uint64_t)tex };
+#else
+        (void)width; (void)height; (void)mipCount; (void)format; (void)usage; (void)label;
+        return {};
+#endif
+    }
+
+    void UploadTexture(idGpuTexture tex, int mip, int x, int y, int width, int height,
+                        const void* pixels, size_t bytesPerRow) override {
+#if D3_WEBGPU_AVAILABLE
+        if (!tex.id) return;
+        WGPUTexelCopyTextureInfo dst = {};
+        dst.texture = (WGPUTexture)tex.id;
+        dst.mipLevel = (uint32_t)mip;
+        dst.origin = { (uint32_t)x, (uint32_t)y, 0 };
+        dst.aspect = WGPUTextureAspect_All;
+        WGPUTexelCopyBufferLayout layout = {};
+        layout.bytesPerRow = (uint32_t)bytesPerRow;
+        layout.rowsPerImage = (uint32_t)height;
+        WGPUExtent3D extent = { (uint32_t)width, (uint32_t)height, 1 };
+        // dataSize: rough estimate of total bytes — bytesPerRow * height
+        wgpuQueueWriteTexture(queue, &dst, pixels, bytesPerRow * (size_t)height,
+                              &layout, &extent);
+#else
+        (void)tex; (void)mip; (void)x; (void)y; (void)width; (void)height;
+        (void)pixels; (void)bytesPerRow;
+#endif
+    }
+
+    void DestroyTexture(idGpuTexture tex) override {
+#if D3_WEBGPU_AVAILABLE
+        if (tex.id) wgpuTextureRelease((WGPUTexture)tex.id);
+#else
+        (void)tex;
+#endif
+    }
+
+    // ─── Samplers — IMPLEMENTED ─────────────────────────────────────────────
+
+    idGpuSampler CreateSampler(bool linearMin, bool linearMag, bool linearMip,
+                                 bool repeatU, bool repeatV) override {
+#if D3_WEBGPU_AVAILABLE
+        WGPUSamplerDescriptor sd = {};
+        sd.minFilter = linearMin ? WGPUFilterMode_Linear : WGPUFilterMode_Nearest;
+        sd.magFilter = linearMag ? WGPUFilterMode_Linear : WGPUFilterMode_Nearest;
