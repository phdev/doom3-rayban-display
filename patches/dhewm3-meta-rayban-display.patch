+(function () {
+	if (typeof callMain === "function") {
+		Module["callMain"] = callMain;
+	}
+	if (typeof ccall === "function") {
+		Module["ccall"] = ccall;
+	}
+	if (typeof cwrap === "function") {
+		Module["cwrap"] = cwrap;
+	}
+	if (typeof FS === "object") {
+		Module["FS"] = FS;
+	}
+	if (typeof FS_createPath === "function") {
+		Module["FS_createPath"] = FS_createPath;
+	}
+	if (typeof FS_createDataFile === "function") {
