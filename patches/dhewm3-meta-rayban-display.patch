+    uint32_t                bloomBGGen = 0, bloomBGCurGen = 0;
+    // Iter 23: Quest-style shadow darkening (union-of-volumes multiply).
+    WGPURenderPipeline      shadowDarkenPipeline = nullptr;
+    WGPUBuffer              shadowDarkenUB = nullptr;
+    WGPUBindGroup           shadowDarkenBG = nullptr;
+    // Iter 6.8: on-device determinism self-test. Renders the identical
+    // record set twice into two offscreen textures, reads both back,
+    // byte-compares. Sidesteps the canvas-readback trap (WebGPU canvases
+    // read back as cleared) — the quantitative replacement for the
+    // eyeball test. If a GPU produces different bytes for identical
+    // command buffers, that's the chunky-tile class of non-determinism.
+    WGPUTexture             detTexA = nullptr, detTexB = nullptr;
+    WGPUTextureView         detViewA = nullptr, detViewB = nullptr;
+    WGPUTexture             detDepthTex = nullptr;
+    WGPUTextureView         detDepthView = nullptr;
+    WGPUBuffer              detBufA = nullptr, detBufB = nullptr;
+    uint32_t                detBytesPerRow = 0;
+    int                     detMapsPending = 0;     // >0 while maps in flight
+    bool                    detMapFailed = false;
+    uint32_t                detFrameCounter = 0;
+    uint32_t                detRoundsDone = 0;
+    static constexpr uint32_t kDetMaxRounds = 6;
+#endif
+};
