+    // Iter 13b: cube texture from the engine cube cache (6 RGBA8 faces).
+    WGPUTextureView getCubeTextureView(const void* imgPtr) {
+        if (!imgPtr) return nullptr;
+        for (int i = 0; i < cubeTexCacheCount; ++i) {
+            if (cubeTexCache[i].ptr == imgPtr) return cubeTexCache[i].view;
+        }
+        const CubeSlot* slot = D3_WebGPU_LookupCubeImage(imgPtr);
+        if (!slot || slot->size <= 0) return nullptr;
+        if (cubeTexCacheCount >= 32) return nullptr;
+        WGPUTextureDescriptor td = {};
+        td.size = { (uint32_t)slot->size, (uint32_t)slot->size, 6 };
+        td.mipLevelCount = 1;
+        td.sampleCount = 1;
+        td.dimension = WGPUTextureDimension_2D;
+        td.format = WGPUTextureFormat_RGBA8Unorm;
+        td.usage = WGPUTextureUsage_TextureBinding | WGPUTextureUsage_CopyDst;
+        WGPUTexture tex = wgpuDeviceCreateTexture(device, &td);
+        if (!tex) return nullptr;
+        for (uint32_t f = 0; f < 6; ++f) {
+            if (!slot->faces[f]) continue;
+            WGPUTexelCopyTextureInfo dst = {};
+            dst.texture = tex;
+            dst.origin = { 0, 0, f };
+            WGPUTexelCopyBufferLayout layout = {};
+            layout.bytesPerRow = (uint32_t)slot->size * 4u;
+            layout.rowsPerImage = (uint32_t)slot->size;
+            WGPUExtent3D ext = { (uint32_t)slot->size, (uint32_t)slot->size, 1 };
+            wgpuQueueWriteTexture(queue, &dst, slot->faces[f],
+                                  (size_t)slot->size * slot->size * 4u, &layout, &ext);
+        }
+        WGPUTextureViewDescriptor vd = {};
+        vd.dimension = WGPUTextureViewDimension_Cube;
+        vd.format = WGPUTextureFormat_RGBA8Unorm;
+        vd.arrayLayerCount = 6;
+        vd.mipLevelCount = 1;
+        WGPUTextureView view = wgpuTextureCreateView(tex, &vd);
+        cubeTexCache[cubeTexCacheCount].ptr = imgPtr;
+        cubeTexCache[cubeTexCacheCount].view = view;
+        cubeTexCacheCount++;
+        return view;
+    }
