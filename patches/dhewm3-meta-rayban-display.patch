+    WGPUTextureView         bloomViewA = nullptr, bloomViewB = nullptr;
+    uint32_t                bloomW = 0, bloomH = 0;
+    uint32_t                bloomGen = 0;
+    WGPUBuffer              bloomUB[4] = {nullptr};      // bright, blurH, blurV, composite
