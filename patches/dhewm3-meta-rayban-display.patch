+            // of THIS frame (g_capLightId grows monotonically across frames,
+            // so filter on the frame-relative id).
+            uint32_t frameMinLightId = 0xFFFFFFFFu;
+            if (g_capWgpuSingleLight >= 0) {
+                for (uint32_t i = 0; i < total; ++i) {
+                    if (scratch[i].pad0 != mainView) continue;
+                    if (scratch[i].lightId < frameMinLightId) frameMinLightId = scratch[i].lightId;
+                }
+            }
+            for (uint32_t i = 0; i < total; ++i) {
+                if (scratch[i].pad0 != mainView) continue;
+                if (g_capWgpuSingleLight >= 0) {
+                    const int rel = (int)(scratch[i].lightId - frameMinLightId);
+                    if (g_capWgpuSingleLight >= 1000) {
+                        // prefix mode: keep lights 0..(N-1000) — bisect tool
+                        if (rel > g_capWgpuSingleLight - 1000) continue;
+                    } else if (rel != g_capWgpuSingleLight) {
+                        continue;
+                    }
+                }
