+                            const Rec& rr = g_passRecords[i];
+                            if (!reflectUniformBufs[rn]) {
+                                WGPUBufferDescriptor d = {};
+                                d.size = 192;
+                                d.usage = WGPUBufferUsage_Uniform | WGPUBufferUsage_CopyDst;
+                                reflectUniformBufs[rn] = wgpuDeviceCreateBuffer(device, &d);
+                            }
+                            const void* cubeImg = g_passImagePtrs[i];
