+        // first use — the two fog images are global and never change.
+        {
+            extern Rec      g_fogRecords[];
+            extern uint32_t g_fogRecordCount;
+            extern void*    g_capFogImgPtr;
+            extern void*    g_capFogEnterImgPtr;
+            uint32_t fn = 0;
