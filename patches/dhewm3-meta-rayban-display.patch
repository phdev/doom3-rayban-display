+			memcpy( r.localViewOrigin,  din->localViewOrigin.ToFloatPtr(),  16 );
+			memcpy( r.lightProjS,       din->lightProjection[0].ToFloatPtr(), 16 );
+			memcpy( r.lightProjT,       din->lightProjection[1].ToFloatPtr(), 16 );
+			memcpy( r.lightProjQ,       din->lightProjection[2].ToFloatPtr(), 16 );
+			memcpy( r.lightFalloffS,    din->lightProjection[3].ToFloatPtr(), 16 );
+			memcpy( r.diffuseColor,     din->diffuseColor.ToFloatPtr(),       16 );
+			memcpy( r.specularColor,    din->specularColor.ToFloatPtr(),      16 );
+			// Iter 7: image pointers per binding slot (matches the order in
+			// RB_ARB2_DrawInteraction below + interaction.wgsl bindings).
+			g_capImagePtrs[g_capRecordCount][0] = (void*)din->bumpImage;
+			g_capImagePtrs[g_capRecordCount][1] = (void*)din->lightFalloffImage;
+			g_capImagePtrs[g_capRecordCount][2] = (void*)din->lightImage;
+			g_capImagePtrs[g_capRecordCount][3] = (void*)din->diffuseImage;
+			g_capImagePtrs[g_capRecordCount][4] = (void*)din->specularImage;
+			g_capVertBytes  += vbytesRound;
+			g_capIndexBytes += ibytesRound;
+			g_capRecordCount++;
+			g_capFrameId++;
+		}
+	}
+	// Iter 4 single-surface compat (used by WebGPU fallback path when record
+	// count is 0). Capture once on the first qualifying interaction.
+	if ( !g_captureSlotUsedThisFrame && din && din->surf && din->surf->geo
+		 && din->surf->geo->verts && din->surf->geo->indexes
+		 && din->surf->geo->numVerts > 0 && din->surf->geo->numIndexes > 0
+		 && din->surf->geo->numVerts   <= kWGPUMaxCapV
+		 && din->surf->geo->numIndexes <= kWGPUMaxCapI ) {
+		memcpy( g_lastSurfVerts, din->surf->geo->verts, din->surf->geo->numVerts * 60 );
+		for ( int i = 0; i < din->surf->geo->numIndexes; ++i ) {
+			g_lastSurfIndexes16[i] = (uint16_t)din->surf->geo->indexes[i];
+		}
+		g_lastSurfNumVerts   = din->surf->geo->numVerts;
+		g_lastSurfNumIndexes = din->surf->geo->numIndexes;
+		if ( din->surf->space && backEnd.viewDef ) {
+			// Full MVP baked at capture (see multi-record comment above)
+			WGPU_MatMul4( g_lastModelMatrix,
+			              backEnd.viewDef->projectionMatrix,
+			              din->surf->space->modelViewMatrix );
+		}
+		memcpy( g_lastDinLocalLightOrigin, din->localLightOrigin.ToFloatPtr(), 16 );
+		memcpy( g_lastDinLocalViewOrigin,  din->localViewOrigin.ToFloatPtr(),  16 );
+		memcpy( g_lastDinLightProjS,       din->lightProjection[0].ToFloatPtr(), 16 );
+		memcpy( g_lastDinLightProjT,       din->lightProjection[1].ToFloatPtr(), 16 );
+		memcpy( g_lastDinLightProjQ,       din->lightProjection[2].ToFloatPtr(), 16 );
+		memcpy( g_lastDinLightFalloffS,    din->lightProjection[3].ToFloatPtr(), 16 );
+		memcpy( g_lastDinDiffuseColor,     din->diffuseColor.ToFloatPtr(),       16 );
+		memcpy( g_lastDinSpecularColor,    din->specularColor.ToFloatPtr(),      16 );
+		g_lastSurfFrameId++;
+		g_captureSlotUsedThisFrame = 1;
+	}
+
 	// load all the vertex program parameters
 	qglProgramEnvParameter4fvARB( GL_VERTEX_PROGRAM_ARB, PP_LIGHT_ORIGIN, din->localLightOrigin.ToFloatPtr() );
 	qglProgramEnvParameter4fvARB( GL_VERTEX_PROGRAM_ARB, PP_VIEW_ORIGIN, din->localViewOrigin.ToFloatPtr() );
