+    WGPUBuffer              fogUniformBufs[64] = {nullptr};
+    WGPUBindGroup           fogBindGroups[64]  = {nullptr};
+    Rec                     lastFogRecords[64] = {};
+    uint32_t                lastFogCount = 0;
+    // Iter 13a: blend lights — filter (DstColor/Zero) + additive variants.
+    WGPURenderPipeline      blendFilterPipeline = nullptr;
+    WGPURenderPipeline      blendAddPipeline = nullptr;
+    WGPUBindGroupLayout     blendBGL = nullptr;
+    WGPUBuffer              blendUniformBufs[64] = {nullptr};
+    WGPUBindGroup           blendBindGroups[64]  = {nullptr};
+    const void*             blendGroupImgs[64][2] = {};
+    Rec                     lastBlendRecords[64] = {};
+    uint32_t                lastBlendCount = 0;
+    // Iter 13b: sky cube stages — second vertex stream of cube directions.
