 int main(int argc, char **argv) {
 	// Prevent running Doom 3 as root
 	// Borrowed from Yamagi Quake II
+	// (Emscripten reports uid 0 in the browser sandbox, so skip the check there.)
+#ifndef __EMSCRIPTEN__
 	if (getuid() == 0) {
 		printf("Doom 3 shouldn't be run as root! Backing out to save your ass. If\n");
 		printf("you really know what you're doing, edit neo/sys/linux/main.cpp and remove\n");
@@ -417,6 +426,7 @@ int main(int argc, char **argv) {
 
 		return 1;
 	}
+#endif
 	// fallback path to the binary for systems without /proc
 	// while not 100% reliable, its good enough
 	if (argc > 0) {
@@ -448,8 +458,16 @@ int main(int argc, char **argv) {
 		common->Init( 0, NULL );
 	}
 
+#ifdef __EMSCRIPTEN__
+	// A blocking while(1) loop never yields to the browser; drive one
+	// common->Frame() per animation frame via the Emscripten main loop instead.
+	// simulate_infinite_loop=1 unwinds the stack and hands control back to the
+	// browser so rendering, input, and timers run.
+	emscripten_set_main_loop( D3_EmscriptenFrame, 0, 1 );
+#else
 	while (1) {
 		common->Frame();
 	}
+#endif
 	return 0;
 }
diff --git a/neo/sys/posix/posix_main.cpp b/neo/sys/posix/posix_main.cpp
index bb0232b..7975128 100644
--- a/neo/sys/posix/posix_main.cpp
+++ b/neo/sys/posix/posix_main.cpp
@@ -565,6 +565,16 @@ Sys_SleepUntilPrecise
 =====================
 */
 void Sys_SleepUntilPrecise( double targetTimeMS ) {
+#ifdef __EMSCRIPTEN__
+	// On WASM there is no real sleep without ASYNCIFY: usleep() AND the
+	// precision busy-loop below both SPIN on the clock, each read a
+	// wasm->JS crossing. Profiling showed ~45% of ALL CPU time burned in
+	// Com_WaitForNextTicStart -> here (emscripten_get_now + nanosleep
+	// spin). The browser's rAF already paces frames — waiting inside the
+	// rAF callback is pure waste (and heat -> throttling on the phone).
+	(void)targetTimeMS;
+	return;
+#else
 	double msec = targetTimeMS - Sys_MillisecondsPrecise();
 	if ( msec < 0.01 ) // don't bother for less than 10usec
 		return;
@@ -590,6 +600,7 @@ void Sys_SleepUntilPrecise( double targetTimeMS ) {
 
 		msec = targetTimeMS - Sys_MillisecondsPrecise();
 	} while ( msec >= 0.01 );
+#endif
 }
 
