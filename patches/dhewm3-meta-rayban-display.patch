+"@group(0) @binding(4) var texMask: texture_2d<f32>;\n"
+"\n"
+"struct VSIn {\n"
+"    @location(0) position:  vec3<f32>,\n"
+"    @location(1) texcoord:  vec2<f32>,\n"
+"    @location(2) normal:    vec3<f32>,\n"
+"    @location(3) tangent:   vec3<f32>,\n"
+"    @location(4) bitangent: vec3<f32>,\n"
