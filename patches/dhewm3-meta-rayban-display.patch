+        // Iter 8c: drain shader-pass (emissive/decal) records the same way —
+        // filter to the main view, write 96-byte texture.wgsl uniforms
+        // (mvp + tint + SVC params), resolve per-(slot,image) bind groups.
+        {
+            extern Rec      g_passRecords[];
+            extern void*    g_passImagePtrs[];
+            extern uint32_t g_passRecordCount;
+            uint32_t pTotal = (g_passRecordCount < kMaxRecordSlots) ? g_passRecordCount : kMaxRecordSlots;
+            uint32_t pn = 0;
+            uint32_t skyN = 0;
+            lastReflectCount = 0;
