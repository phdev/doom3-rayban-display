+# Meta Ray-Ban Display: Emscripten / WebAssembly target (experimental).
+# Produces dhewm3.js / dhewm3.wasm / dhewm3.data and exposes the D3_* wearable
+# bridge to JavaScript. The runtime is driven by the web app shell in
+# https://github.com/phdev/doom3-rayban-display .
+if(EMSCRIPTEN)
+	# D3_EMSCRIPTEN_EMBED may point at a directory whose contents are baked into
+	# dhewm3.data (e.g. base/autoexec.cfg and an optional reduced pak-display.pk4).
+	if(NOT DEFINED D3_EMSCRIPTEN_EMBED)
+		set(D3_EMSCRIPTEN_EMBED "${CMAKE_SOURCE_DIR}/sys/wasm/embed")
+	endif()
+
+	set(d3_wasm_exports "[\"_main\",\"_D3_AddViewAngles\",\"_D3_SetViewYaw\",\"_D3_SetWearableAction\",\"_D3_ExecCommand\",\"_D3_GetEnemyIndicators\",\"_D3_GetEnemyYaw\",\"_D3_RequestEnemyTurn\",\"_D3_SetEnemyIndicators\",\"_D3_SetEnemyIndicatorYaw\",\"_D3_ConsumeEnemyTurn\"]")
+
+	# The game module is hard-linked (HARDLINK_GAME), so no dynamic linking /
+	# MAIN_MODULE is required. SDL2 comes from Emscripten's built-in port, GL
+	# from GL4ES translated to WebGL2.
+	set(d3_wasm_ldflags
+		"-sUSE_SDL=3"
+		"-fexceptions"
+		"-sFULL_ES2=1 -sFULL_ES3=1 -sMIN_WEBGL_VERSION=1 -sMAX_WEBGL_VERSION=2"
+		# SDL3 creates the WebGL context directly on the "#gameCanvas" element
+		# (selected via SDL_HINT_EMSCRIPTEN_CANVAS_SELECTOR in GLimp_Init) and
+		# presents it with SDL_GL_SwapWindow, matching the proven Qwasm2 GL4ES path.
+		# 256MB initial (was 512): iOS Safari jetsam-kills tabs on total memory —
+		# committing 512MB before the pak even loads ate half the budget up
+		# front. Growth covers actual demand (~400MB peak with the 66MB pak).
+		"-sINITIAL_MEMORY=256MB -sALLOW_MEMORY_GROWTH=1 -sMAXIMUM_MEMORY=2GB -sSTACK_SIZE=8MB"
+		"-sEXPORTED_FUNCTIONS=${d3_wasm_exports}"
+		"-sEXPORTED_RUNTIME_METHODS=[\"ccall\",\"cwrap\",\"FS\",\"callMain\",\"HEAP8\"]"
+		"-sEXIT_RUNTIME=0 -sINVOKE_RUN=0 -sERROR_ON_UNDEFINED_SYMBOLS=0"
+		"--post-js ${CMAKE_SOURCE_DIR}/sys/wasm/d3_runtime_exports.js"
+		"--preload-file ${D3_EMSCRIPTEN_EMBED}@/"
+		"-lidbfs.js -lopenal"
+	)
+
+	# Debug aid: -DD3_PROFILING_FUNCS=ON relinks with function names kept in
+	# the wasm so traps ("null function or function signature mismatch")
+	# produce NAMED stack traces. Adds ~1-2MB; never ship it.
+	option(D3_PROFILING_FUNCS "Keep wasm function names for stack traces" OFF)
+	if(D3_PROFILING_FUNCS)
+		list(APPEND d3_wasm_ldflags "--profiling-funcs")
+	endif()
+	string(REPLACE ";" " " d3_wasm_ldflags "${d3_wasm_ldflags}")
+	set(ldflags "${ldflags} ${d3_wasm_ldflags}")
+
+	# SDL2 headers come from the Emscripten port at compile time; GL headers
+	# come from GL4ES (added via -I in the build script). -fexceptions makes
+	# C++ try/catch work (Emscripten disables it by default), so dhewm3's
+	# recoverable idException errors drop to the console instead of aborting.
+	add_compile_options(-sUSE_SDL=3 -fPIC -fexceptions)
+endif()
