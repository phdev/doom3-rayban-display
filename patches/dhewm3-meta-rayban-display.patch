+                                WGPUTextureView cv = getCubeTextureView(cubeImg);
+                                if (cv) {
+                                    WGPUBindGroupEntry e[3] = {};
+                                    e[0].binding = 0; e[0].buffer = reflectUniformBufs[rn]; e[0].size = 192;
+                                    e[1].binding = 1; e[1].sampler = interactionLightSampler;
+                                    e[2].binding = 2; e[2].textureView = cv;
+                                    WGPUBindGroupDescriptor bgd = {};
+                                    bgd.layout = reflectBGL;
+                                    bgd.entryCount = 3;
+                                    bgd.entries = e;
