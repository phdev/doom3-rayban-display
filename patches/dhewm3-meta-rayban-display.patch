+    Rec                     lastSkyRecords[16] = {};
+    uint32_t                lastSkyCount = 0;
+    struct CubeTexEntry { const void* ptr; WGPUTextureView view; };
+    CubeTexEntry            cubeTexCache[32] = {};
+    int                     cubeTexCacheCount = 0;
