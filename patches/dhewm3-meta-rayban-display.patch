+private:
+#if D3_WEBGPU_AVAILABLE
+    WGPUDevice              device           = nullptr;
+    WGPUQueue               queue            = nullptr;
+    WGPUSurface             surface          = nullptr;
+    WGPUTextureFormat       surfaceFormat    = WGPUTextureFormat_Undefined;
+    WGPUCommandEncoder      cmdEncoder       = nullptr;
+    WGPURenderPassEncoder   renderPass       = nullptr;
+    WGPURenderPipeline      currentPipeline  = nullptr;
+    // Iter 1 demo
+    bool                    demoInit         = false;
+    WGPURenderPipeline      demoPipeline     = nullptr;
+    WGPUBuffer              demoVertexBuf    = nullptr;
+    WGPUBuffer              demoUniformBuf   = nullptr;
+    WGPUTexture             demoTexture      = nullptr;
+    WGPUSampler             demoSampler      = nullptr;
+    WGPUBindGroup           demoBindGroup    = nullptr;
+    // Iter 4/7b: interaction.wgsl pipeline (DOOM 3 lit pass, additive)
+    WGPURenderPipeline      interactionPipeline = nullptr;
+    WGPUSampler             interactionMaterialSampler = nullptr;
+    WGPUSampler             interactionLightSampler = nullptr;
+    // Iter 7b: z-fill pre-pass pipeline (depth.wgsl, no fragment stage)
+    WGPURenderPipeline      depthPipeline = nullptr;
+    // Iter 5: depth buffer (canvas-sized; shared by pre-pass + lit pass)
+    WGPUTexture             depthTexture = nullptr;
+    WGPUTextureView         depthView    = nullptr;
+    int                     depthW = 0, depthH = 0;
+    // Iter 6/7b: multi-surface mirror — one big GPU vertex/index buffer
+    // holds the engine's per-frame accumulated geometry; per-slot uniform
+    // buffers + per-slot group(0) bind groups (one set for the interaction
+    // pipeline layout, one for the depth pipeline layout). Material
+    // textures live in group(1), cached per unique 5-image tuple.
+    static constexpr uint32_t kMaxRecordSlots = 896;   // mirrors kWGPUMaxRecords
+    WGPUBuffer              recordVertexBuf = nullptr;
+    WGPUBuffer              recordIndexBuf  = nullptr;
+    uint32_t                recordVertexCap = 0;   // bytes
+    uint32_t                recordIndexCap  = 0;   // bytes
+    WGPUBuffer              recordUniformBufs[kMaxRecordSlots] = {nullptr};
+    WGPUBindGroup           recordBindGroups[kMaxRecordSlots]  = {nullptr};
+    WGPUBindGroup           recordDepthBindGroups[kMaxRecordSlots] = {nullptr};
+    bool                    recordSlotsReady = false;
+    uint32_t                lastUploadedCapFrameId = 0;
+    // Iter 6.6: backend-local copy of the last consumed records — the draw
+    // loop reads offsets/counts from here; frames with no fresh capture
+    // (GUI-only frames) redraw this set.
+    Rec                     lastRecords[kMaxRecordSlots] = {};
+    uint32_t                lastRecordCount = 0;
+    WGPUBindGroup           lastMatGroups[kMaxRecordSlots] = {nullptr};
+    // Iter 7b: GPU texture cache (engine idImage ptr → WGPUTextureView) and
+    // material bind-group cache (5-image tuple → group(1) bind group).
+    static constexpr uint32_t kTexCacheSize = 2048;
+    static constexpr uint32_t kMatCacheSize = 1024;
+    struct TexCacheEntry { const void* ptr; WGPUTextureView view; };
+    struct MatCacheEntry { void* key[5]; WGPUBindGroup group; };
+    TexCacheEntry           texCache[kTexCacheSize] = {};
+    MatCacheEntry           matCache[kMatCacheSize] = {};
+    int                     texCacheCount = 0;
+    int                     matCacheCount = 0;
+    bool                    matCacheOverflowWarned = false;
+    WGPUTextureView         fbFlatNormalView = nullptr;
+    WGPUTextureView         fbWhiteView      = nullptr;
+    WGPUTextureView         fbCheckerView    = nullptr;
+    WGPUBindGroup           fbMatGroup       = nullptr;
+    // Iter 8c: shader-pass (emissive/decal) echo. Records share the Rec
+    // shape (diffuseColor = stage color, pad1 = blend kind, pad2 = SVC).
+    // Pipelines: opaque reuses demoPipeline (One/Zero, depth write ON);
+    // additive + alpha get texture.wgsl variants (depth write OFF).
+    WGPURenderPipeline      passOpaquePipeline = nullptr;
+    WGPURenderPipeline      passAddPipeline   = nullptr;
+    WGPURenderPipeline      passAlphaPipeline = nullptr;
+    WGPURenderPipeline      passFilterPipeline = nullptr;
+    // Iter 8d: 2D GUI/HUD variants — depth test Always (overlay)
+    WGPURenderPipeline      guiAddPipeline    = nullptr;
+    WGPURenderPipeline      guiAlphaPipeline  = nullptr;
+    WGPUBindGroupLayout     passBGL           = nullptr;
+    WGPUBuffer              passUniformBufs[kMaxRecordSlots] = {nullptr};
+    Rec                     lastPassRecords[kMaxRecordSlots] = {};
+    WGPUBindGroup           lastPassGroups[kMaxRecordSlots]  = {nullptr};
+    uint32_t                lastPassCount = 0;
+    struct PassBGEntry { uint32_t slot; const void* img; WGPUBindGroup group; };
+    static constexpr uint32_t kPassBGCacheSize = 1024;
+    PassBGEntry             passBGCache[kPassBGCacheSize] = {};
+    uint32_t                passBGCacheCount = 0;
+    bool                    passBGOverflowWarned = false;
+    // Iter 9: stencil shadow volumes — two pipelines (z-fail for volumes
+    // the view is inside, depth-pass for external ones), vec4 vertex
+    // stream, per-slot 80-byte uniforms (mvp + model-space light origin).
+    WGPURenderPipeline      shadowZFailPipeline = nullptr;
+    WGPURenderPipeline      shadowZPassPipeline = nullptr;
+    WGPUBindGroupLayout     shadowBGL = nullptr;
+    WGPUBuffer              shadowUniformBufs[kMaxRecordSlots] = {nullptr};
+    WGPUBindGroup           shadowBindGroups[kMaxRecordSlots]  = {nullptr};
+    WGPUBuffer              shadowVertexBuf = nullptr;
+    uint32_t                shadowVertexCap = 0;
+    Rec                     lastShadowRecords[kMaxRecordSlots] = {};
+    uint32_t                lastShadowCount = 0;
