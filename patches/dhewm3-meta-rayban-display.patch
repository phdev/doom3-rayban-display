+                const Rec& r = lastBlendRecords[i];
+                WGPURenderPipeline p = (r.pad1 == 1u) ? blendFilterPipeline : blendAddPipeline;
+                if (!p || !blendBindGroups[i]) continue;
+                wgpuRenderPassEncoderSetPipeline(rp, p);
+                wgpuRenderPassEncoderSetBindGroup(rp, 0, blendBindGroups[i], 0, nullptr);
+                wgpuRenderPassEncoderSetVertexBuffer(rp, 0, recordVertexBuf, r.vertOffset, (uint64_t)r.vertCount * 60u);
+                wgpuRenderPassEncoderSetIndexBuffer(rp, recordIndexBuf, WGPUIndexFormat_Uint16, r.indexOffset, (uint64_t)r.indexCount * 2u);
+                wgpuRenderPassEncoderDrawIndexed(rp, r.indexCount, 1, 0, 0, 0);
+            }
+            for (uint32_t i = 0; i < lastPassCount; ++i) {
+                const Rec& r = lastPassRecords[i];
+                if (splitGUI && r.pad3 == 1u) continue;   // GUI draws after post-FX
+                WGPURenderPipeline p;
+                if (r.pad3 == 1u) {
+                    p = (r.pad1 == 2u) ? guiAddPipeline : guiAlphaPipeline;
+                } else {
+                    p = (r.pad1 == 1u) ? passOpaquePipeline
+                      : (r.pad1 == 3u) ? passAlphaPipeline
+                      : (r.pad1 == 4u) ? passFilterPipeline
+                      : passAddPipeline;
+                }
+                if (!p || !lastPassGroups[i]) continue;
+                wgpuRenderPassEncoderSetPipeline(rp, p);
+                wgpuRenderPassEncoderSetBindGroup(rp, 0, lastPassGroups[i], 0, nullptr);
+                wgpuRenderPassEncoderSetVertexBuffer(rp, 0, recordVertexBuf, r.vertOffset, (uint64_t)r.vertCount * 60u);
+                wgpuRenderPassEncoderSetIndexBuffer(rp, recordIndexBuf, WGPUIndexFormat_Uint16, r.indexOffset, (uint64_t)r.indexCount * 2u);
+                wgpuRenderPassEncoderDrawIndexed(rp, r.indexCount, 1, 0, 0, 0);
+            }
+            wgpuRenderPassEncoderEnd(rp);
+            wgpuRenderPassEncoderRelease(rp);
+
+            // Iter 16 part B: copy the frame so far, then draw the haze
+            // surfaces (deflected samples of the copy) and the GUI overlay.
+            if (hazeActive) {
+                WGPUTexelCopyTextureInfo src = {};
+                src.texture = colorTex;
+                WGPUTexelCopyTextureInfo dst = {};
+                dst.texture = currentRenderTex;
+                WGPUExtent3D ext = { currentRenderW, currentRenderH, 1 };
+                wgpuCommandEncoderCopyTextureToTexture(enc, &src, &dst, &ext);
+
+                ca.loadOp = WGPULoadOp_Load;
+                WGPURenderPassEncoder rp2 = wgpuCommandEncoderBeginRenderPass(enc, &rpd);
+                if (hazeVertexBuf && hazeIndexBuf) {
+                    wgpuRenderPassEncoderSetPipeline(rp2, hazePipeline);
+                    for (uint32_t i = 0; i < lastHazeCount; ++i) {
+                        const Rec& r = lastHazeRecords[i];
+                        if (!hazeBindGroups[i]) continue;
+                        wgpuRenderPassEncoderSetBindGroup(rp2, 0, hazeBindGroups[i], 0, nullptr);
+                        wgpuRenderPassEncoderSetVertexBuffer(rp2, 0, hazeVertexBuf, r.vertOffset, (uint64_t)r.vertCount * 60u);
+                        wgpuRenderPassEncoderSetIndexBuffer(rp2, hazeIndexBuf, WGPUIndexFormat_Uint16, r.indexOffset, (uint64_t)r.indexCount * 2u);
+                        wgpuRenderPassEncoderDrawIndexed(rp2, r.indexCount, 1, 0, 0, 0);
+                    }
+                }
+                wgpuRenderPassEncoderEnd(rp2);
+                wgpuRenderPassEncoderRelease(rp2);
+            }
+
+            // Iter 19: bloom — copy the (post-haze) frame, bright-pass it
+            // into the quarter-res target, blur H+V, composite additively.
+            if (bloomActive) {
+                ensureCurrentRenderTarget((uint32_t)depthW, (uint32_t)depthH);
+                ensureBloomTargets((uint32_t)depthW, (uint32_t)depthH);
+                if (currentRenderTex && currentRenderView && bloomViewA && bloomViewB &&
+                    currentRenderW == (uint32_t)depthW && currentRenderH == (uint32_t)depthH) {
+                    WGPUTexelCopyTextureInfo src = {};
+                    src.texture = colorTex;
+                    WGPUTexelCopyTextureInfo dst = {};
+                    dst.texture = currentRenderTex;
+                    WGPUExtent3D ext = { currentRenderW, currentRenderH, 1 };
+                    wgpuCommandEncoderCopyTextureToTexture(enc, &src, &dst, &ext);
+
+                    // tunables (live via d3cmd r_bloomThreshold / r_bloomScale)
+                    const float tw = 1.0f / (float)bloomW, th = 1.0f / (float)bloomH;
+                    float ub0[8] = { g_capBloomThresh, 0, 0, 0,            0, 0, 0, 0 };   // bright
+                    float ub1[8] = { 0, 0, tw, th,                          1, 0, 0, 0 };   // blur H
+                    float ub2[8] = { 0, 0, tw, th,                          0, 1, 0, 0 };   // blur V
+                    float ub3[8] = { 0, g_capBloomScale, 0, 0,              0, 0, 0, 0 };   // composite
+                    wgpuQueueWriteBuffer(queue, bloomUB[0], 0, ub0, 32);
+                    wgpuQueueWriteBuffer(queue, bloomUB[1], 0, ub1, 32);
+                    wgpuQueueWriteBuffer(queue, bloomUB[2], 0, ub2, 32);
+                    wgpuQueueWriteBuffer(queue, bloomUB[3], 0, ub3, 32);
+
+                    // bind groups: rebuilt when the copy target or bloom
+                    // targets were recreated
+                    if (bloomBGGen != currentRenderGen || bloomBGCurGen != bloomGen || !bloomBG[0]) {
+                        WGPUTextureView ins[4] = { currentRenderView, bloomViewA, bloomViewB, bloomViewA };
+                        for (int i = 0; i < 4; ++i) {
+                            if (bloomBG[i]) { wgpuBindGroupRelease(bloomBG[i]); bloomBG[i] = nullptr; }
+                            WGPUBindGroupEntry e[3] = {};
+                            e[0].binding = 0; e[0].buffer = bloomUB[i]; e[0].size = 32;
+                            e[1].binding = 1; e[1].sampler = interactionLightSampler;
+                            e[2].binding = 2; e[2].textureView = ins[i];
+                            WGPUBindGroupDescriptor bgd = {};
+                            bgd.layout = bloomBGL;
+                            bgd.entryCount = 3;
+                            bgd.entries = e;
+                            bloomBG[i] = wgpuDeviceCreateBindGroup(device, &bgd);
+                        }
+                        bloomBGGen = currentRenderGen;
+                        bloomBGCurGen = bloomGen;
+                    }
+
+                    auto fxPass = [&](WGPUTextureView target, WGPULoadOp load,
+                                      WGPURenderPipeline pipe, WGPUBindGroup bg) {
+                        WGPURenderPassColorAttachment fca = {};
+                        fca.view = target;
+                        fca.loadOp = load;
+                        fca.storeOp = WGPUStoreOp_Store;
+                        fca.clearValue = { 0.0, 0.0, 0.0, 1.0 };
+                        fca.depthSlice = WGPU_DEPTH_SLICE_UNDEFINED;
+                        WGPURenderPassDescriptor frpd = {};
+                        frpd.colorAttachmentCount = 1;
+                        frpd.colorAttachments = &fca;
+                        WGPURenderPassEncoder frp = wgpuCommandEncoderBeginRenderPass(enc, &frpd);
+                        wgpuRenderPassEncoderSetPipeline(frp, pipe);
+                        wgpuRenderPassEncoderSetBindGroup(frp, 0, bg, 0, nullptr);
+                        wgpuRenderPassEncoderDraw(frp, 3, 1, 0, 0);
+                        wgpuRenderPassEncoderEnd(frp);
+                        wgpuRenderPassEncoderRelease(frp);
+                    };
+                    fxPass(bloomViewA, WGPULoadOp_Clear, bloomBrightPipeline, bloomBG[0]);
+                    fxPass(bloomViewB, WGPULoadOp_Clear, bloomBlurPipeline,   bloomBG[1]);
+                    fxPass(bloomViewA, WGPULoadOp_Clear, bloomBlurPipeline,   bloomBG[2]);
+                    fxPass(color,      WGPULoadOp_Load,  bloomCompositePipeline, bloomBG[3]);
+                }
+            }
+
+            // GUI overlay last (post-FX must not bloom/warp the HUD).
+            if (splitGUI) {
+                ca.loadOp = WGPULoadOp_Load;
+                WGPURenderPassEncoder rp3 = wgpuCommandEncoderBeginRenderPass(enc, &rpd);
+                for (uint32_t i = 0; i < lastPassCount; ++i) {
+                    const Rec& r = lastPassRecords[i];
+                    if (r.pad3 != 1u) continue;
+                    WGPURenderPipeline p = (r.pad1 == 2u) ? guiAddPipeline : guiAlphaPipeline;
+                    if (!p || !lastPassGroups[i]) continue;
+                    wgpuRenderPassEncoderSetPipeline(rp3, p);
+                    wgpuRenderPassEncoderSetBindGroup(rp3, 0, lastPassGroups[i], 0, nullptr);
+                    wgpuRenderPassEncoderSetVertexBuffer(rp3, 0, recordVertexBuf, r.vertOffset, (uint64_t)r.vertCount * 60u);
+                    wgpuRenderPassEncoderSetIndexBuffer(rp3, recordIndexBuf, WGPUIndexFormat_Uint16, r.indexOffset, (uint64_t)r.indexCount * 2u);
+                    wgpuRenderPassEncoderDrawIndexed(rp3, r.indexCount, 1, 0, 0, 0);
+                }
+                wgpuRenderPassEncoderEnd(rp3);
+                wgpuRenderPassEncoderRelease(rp3);
+            }
+        }
+    }
+
+    // All-fallback material group for records whose resolve failed.
+    WGPUBindGroup fallbackMatGroup() {
+        if (!fbMatGroup) {
+            void* nulls[5] = { nullptr, nullptr, nullptr, nullptr, nullptr };
+            fbMatGroup = getMaterialBindGroup(nulls);
+        }
+        return fbMatGroup;
+    }
