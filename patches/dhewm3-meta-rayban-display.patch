+static const char* const kWGSL_haze = "// haze.wgsl — heat-haze / screen-distortion new-stage echo (iter 16).\n"
+"//\n"
+"// Replicates glprogs/heatHaze.vfp, heatHazeWithMask.vfp and\n"
