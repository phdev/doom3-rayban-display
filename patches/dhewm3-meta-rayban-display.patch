+            static Rec scratch[kMaxRecordSlots];
+            static void* scratchImgs[kMaxRecordSlots][5];
+            memcpy(scratch, g_capRecords, total * sizeof(Rec));
+            memcpy(scratchImgs, g_capImagePtrs, total * sizeof(void*) * 5);
