+        pd.vertex.buffers = layouts;
+        pd.primitive.topology = WGPUPrimitiveTopology_TriangleList;
+        pd.primitive.cullMode = WGPUCullMode_None;
+        pd.multisample.count = 1;
+        pd.multisample.mask = 0xFFFFFFFF;
+        pd.fragment = &frag;
+        pd.depthStencil = &dss;
+        skyPipeline = wgpuDeviceCreateRenderPipeline(device, &pd);
+        wgpuPipelineLayoutRelease(pl);
+        wgpuShaderModuleRelease(mod);
+    }
+
+    // Iter 15b: reflect pipeline (reflect.wgsl) — opaque env-mapped surfaces.
+    void initReflectPipeline() {
+        WGPUShaderSourceWGSL wgsl = {};
+        wgsl.chain.sType = WGPUSType_ShaderSourceWGSL;
+        wgsl.code = { kWGSL_reflect, WGPU_STRLEN };
+        WGPUShaderModuleDescriptor smd = {};
+        smd.nextInChain = &wgsl.chain;
+        WGPUShaderModule mod = wgpuDeviceCreateShaderModule(device, &smd);
+        if (!mod) { fprintf(stderr, "[WebGPU] reflect.wgsl create FAILED\n"); return; }
+        WGPUBindGroupLayoutEntry ble[3] = {};
+        ble[0].binding = 0;
+        ble[0].visibility = WGPUShaderStage_Vertex | WGPUShaderStage_Fragment;
+        ble[0].buffer.type = WGPUBufferBindingType_Uniform;
+        ble[0].buffer.minBindingSize = 192;
+        ble[1].binding = 1;
+        ble[1].visibility = WGPUShaderStage_Fragment;
+        ble[1].sampler.type = WGPUSamplerBindingType_Filtering;
+        ble[2].binding = 2;
+        ble[2].visibility = WGPUShaderStage_Fragment;
+        ble[2].texture.sampleType = WGPUTextureSampleType_Float;
+        ble[2].texture.viewDimension = WGPUTextureViewDimension_Cube;
+        WGPUBindGroupLayoutDescriptor bld = {};
+        bld.entryCount = 3;
+        bld.entries = ble;
+        reflectBGL = wgpuDeviceCreateBindGroupLayout(device, &bld);
+        WGPUPipelineLayoutDescriptor pld = {};
+        pld.bindGroupLayoutCount = 1;
+        pld.bindGroupLayouts = &reflectBGL;
+        WGPUPipelineLayout pl = wgpuDeviceCreatePipelineLayout(device, &pld);
+
+        WGPUDepthStencilState dss = {};
+        dss.format = WGPUTextureFormat_Depth24PlusStencil8;
+        dss.depthWriteEnabled = WGPUOptionalBool_True;
+        dss.depthCompare = WGPUCompareFunction_LessEqual;
+        dss.stencilFront.compare = WGPUCompareFunction_Always;
+        dss.stencilBack.compare  = WGPUCompareFunction_Always;
+        dss.stencilFront.failOp = dss.stencilFront.depthFailOp = dss.stencilFront.passOp = WGPUStencilOperation_Keep;
+        dss.stencilBack.failOp  = dss.stencilBack.depthFailOp  = dss.stencilBack.passOp  = WGPUStencilOperation_Keep;
+        WGPUColorTargetState target = {};
+        target.format = surfaceFormat;
+        target.writeMask = WGPUColorWriteMask_All;
+        WGPUBlendState blend = {};
+        blend.color.srcFactor = WGPUBlendFactor_One; blend.color.dstFactor = WGPUBlendFactor_Zero;
+        blend.alpha.srcFactor = WGPUBlendFactor_One; blend.alpha.dstFactor = WGPUBlendFactor_Zero;
+        target.blend = &blend;
+        WGPUFragmentState frag = {};
+        frag.module = mod;
+        frag.entryPoint = { "fs_main", WGPU_STRLEN };
+        frag.targetCount = 1;
+        frag.targets = &target;
+        WGPURenderPipelineDescriptor pd = {};
+        pd.label = { "reflect", WGPU_STRLEN };
+        pd.layout = pl;
+        pd.vertex.module = mod;
+        pd.vertex.entryPoint = { "vs_main", WGPU_STRLEN };
+        pd.vertex.bufferCount = 1;
+        pd.vertex.buffers = drawVertLayout();
+        pd.primitive.topology = WGPUPrimitiveTopology_TriangleList;
+        pd.primitive.cullMode = WGPUCullMode_None;
+        pd.multisample.count = 1;
+        pd.multisample.mask = 0xFFFFFFFF;
+        pd.fragment = &frag;
+        pd.depthStencil = &dss;
+        reflectPipeline = wgpuDeviceCreateRenderPipeline(device, &pd);
+        wgpuPipelineLayoutRelease(pl);
+        wgpuShaderModuleRelease(mod);
+    }
+
+    // Iter 8c: bind group for a shader-pass record slot — texture.wgsl
+    // group(0) = uniform + sampler + texture. Cached per (slot, image).
+    WGPUBindGroup getPassBindGroup(uint32_t slot, const void* imgPtr) {
+        for (uint32_t i = 0; i < passBGCacheCount; ++i) {
+            if (passBGCache[i].slot == slot && passBGCache[i].img == imgPtr) {
+                return passBGCache[i].group;
+            }
+        }
+        WGPUTextureView view = getEngineTextureView(imgPtr, fbWhiteView);
+        WGPUBindGroupEntry e[3] = {};
+        e[0].binding = 0; e[0].buffer = passUniformBufs[slot]; e[0].size = 128;
+        e[1].binding = 1; e[1].sampler = demoSampler;
+        e[2].binding = 2; e[2].textureView = view;
+        WGPUBindGroupDescriptor bgd = {};
+        bgd.layout = passBGL;
+        bgd.entryCount = 3;
+        bgd.entries = e;
+        WGPUBindGroup g = wgpuDeviceCreateBindGroup(device, &bgd);
+        if (passBGCacheCount < kPassBGCacheSize) {
+            passBGCache[passBGCacheCount].slot = slot;
+            passBGCache[passBGCacheCount].img = imgPtr;
+            passBGCache[passBGCacheCount].group = g;
+            passBGCacheCount++;
+        } else if (!passBGOverflowWarned) {
+            passBGOverflowWarned = true;
+            EM_ASM({ console.warn("[d3] WebGPU pass bind-group cache full; transient groups will leak"); });
+        }
+        return g;
+    }
+
+    // Iter 17: pass bind group sampling a per-slot cinematic frame texture.
+    // Built fresh each frame (the frame content changes every frame anyway);
+    // retired at the next drain once the prior submit completed.
+    WGPUBindGroup getCinPassBindGroup(uint32_t slot, uint32_t cin) {
+        if (cin >= kCinSlots || !cinView[cin] || !passUniformBufs[slot]) return nullptr;
+        WGPUBindGroupEntry e[3] = {};
+        e[0].binding = 0; e[0].buffer = passUniformBufs[slot]; e[0].size = 128;
+        e[1].binding = 1; e[1].sampler = demoSampler;
+        e[2].binding = 2; e[2].textureView = cinView[cin];
+        WGPUBindGroupDescriptor bgd = {};
+        bgd.layout = passBGL;
+        bgd.entryCount = 3;
+        bgd.entries = e;
+        WGPUBindGroup g = wgpuDeviceCreateBindGroup(device, &bgd);
+        // park it for release at the next drain (one transient per cin slot
+        // per frame is the common case; extras replace and release eagerly)
+        if (cinFrameGroups[cin]) wgpuBindGroupRelease(cinFrameGroups[cin]);
+        cinFrameGroups[cin] = g;
+        return g;
+    }
+
+    // Iter 8b: z-fill pre-pass pipeline. No fragment stage, no color
+    // targets — writes depth only. The lit pass then tests LessEqual with
+    // depth writes off, giving correct occlusion AND letting multiple
+    // light passes of the same surface accumulate at equal depth.
+    //
+    // CRITICAL: built from interaction.wgsl's vs_main — the SAME module and
+    // entry point as the lit pipeline — so both compute bit-identical clip
+    // positions. A separate depth-only shader source risks the compiler
+    // ordering the position math differently between pipelines; a 1-ulp
+    // clip-z difference makes LessEqual reject every lit fragment (black
+    // echo). depth.wgsl stays in the tree for future true depth-only uses.
+    void initDepthPipeline() {
+        WGPUShaderSourceWGSL wgsl = {};
+        wgsl.chain.sType = WGPUSType_ShaderSourceWGSL;
+        wgsl.code = { kWGSL_interaction, WGPU_STRLEN };
+        WGPUShaderModuleDescriptor smd = {};
+        smd.nextInChain = &wgsl.chain;
+        WGPUShaderModule mod = wgpuDeviceCreateShaderModule(device, &smd);
+        if (!mod) { fprintf(stderr, "[WebGPU] prepass shader create FAILED\n"); return; }
+
+        WGPUDepthStencilState dss = {};
+        dss.format = WGPUTextureFormat_Depth24PlusStencil8;
+        dss.depthWriteEnabled = WGPUOptionalBool_True;
+        dss.depthCompare = WGPUCompareFunction_LessEqual;
+        dss.stencilFront.compare = WGPUCompareFunction_Always;
+        dss.stencilBack.compare  = WGPUCompareFunction_Always;
+        dss.stencilFront.failOp = dss.stencilFront.depthFailOp = dss.stencilFront.passOp = WGPUStencilOperation_Keep;
+        dss.stencilBack.failOp  = dss.stencilBack.depthFailOp  = dss.stencilBack.passOp  = WGPUStencilOperation_Keep;
+
+        WGPURenderPipelineDescriptor pd = {};
+        pd.label = { "depthPrepass", WGPU_STRLEN };
+        pd.vertex.module = mod;
+        pd.vertex.entryPoint = { "vs_main", WGPU_STRLEN };
+        pd.vertex.bufferCount = 1;
+        pd.vertex.buffers = drawVertLayout();
+        pd.primitive.topology = WGPUPrimitiveTopology_TriangleList;
+        pd.primitive.cullMode = WGPUCullMode_None;
+        pd.multisample.count = 1;
+        pd.multisample.mask = 0xFFFFFFFF;
+        pd.fragment = nullptr;          // depth-only
+        pd.depthStencil = &dss;
+        depthPipeline = wgpuDeviceCreateRenderPipeline(device, &pd);
+        wgpuShaderModuleRelease(mod);
+        if (!depthPipeline) { fprintf(stderr, "[WebGPU] depth pipeline FAILED\n"); return; }
+    }
+
+    // Iter 7b: small procedural texture helper (fallbacks for images that
+    // aren't in the CPU cache).
+    WGPUTextureView makeFillTex(uint32_t fill, const char* label) {
+        const int M = 4;
+        uint32_t pixels[M*M];
+        for (int i = 0; i < M*M; ++i) pixels[i] = fill;
+        WGPUTextureDescriptor td = {};
+        td.size = { (uint32_t)M, (uint32_t)M, 1 };
+        td.mipLevelCount = 1;
+        td.sampleCount = 1;
+        td.dimension = WGPUTextureDimension_2D;
+        td.format = WGPUTextureFormat_RGBA8Unorm;
+        td.usage = WGPUTextureUsage_TextureBinding | WGPUTextureUsage_CopyDst;
+        td.label = { label, WGPU_STRLEN };
+        WGPUTexture tex = wgpuDeviceCreateTexture(device, &td);
+        WGPUTexelCopyTextureInfo dst = {};
+        dst.texture = tex;
+        WGPUTexelCopyBufferLayout layout = {};
+        layout.bytesPerRow = M * 4; layout.rowsPerImage = M;
+        WGPUExtent3D extent = { (uint32_t)M, (uint32_t)M, 1 };
+        wgpuQueueWriteTexture(queue, &dst, pixels, sizeof(pixels), &layout, &extent);
+        // Texture handle intentionally not stored — lives for the session.
+        return wgpuTextureCreateView(tex, nullptr);
+    }
+
+    // Names an unresolvable image once — turns "flat tinted quad" reports
+    // into an actionable image list (helper lives in tr_render.cpp).
+    void noteImageFallback(const void* imgPtr, const char* why) {
+        static const void* seen[24] = {};
+        static int seenCount = 0;
+        for (int i = 0; i < seenCount; ++i) if (seen[i] == imgPtr) return;
+        if (seenCount >= 24) return;
+        seen[seenCount++] = imgPtr;
+        EM_ASM_({ console.info("[d3] WebGPU image FALLBACK (" + UTF8ToString($1) + "): " + UTF8ToString($0)); },
+                D3_WebGPU_ImageName(imgPtr), why);
+    }
+
+    // Iter 7b: GPU mirror of the engine's CPU image cache. One texture per
+    // idImage pointer, created+uploaded on first use.
+    WGPUTextureView getEngineTextureView(const void* imgPtr, WGPUTextureView fallback) {
+        if (!imgPtr) return fallback;
+        // Iter 14: linked subview render targets shadow the engine image.
+        for (uint32_t i = 0; i < g_subviewLinkCount && i < kMaxSubviews; ++i) {
+            if (g_subviewLinks[i].img == imgPtr && subviewView[i]) return subviewView[i];
+        }
+        for (int i = 0; i < texCacheCount; ++i) {
+            if (texCache[i].ptr == imgPtr) return texCache[i].view;
+        }
+        const ImgSlot* slot = D3_WebGPU_LookupCachedImage(imgPtr);
+        if (!slot || !slot->pixels || slot->w <= 0 || slot->h <= 0) { noteImageFallback(imgPtr, "cpu-miss"); return fallback; }
+        if (texCacheCount >= (int)kTexCacheSize) { noteImageFallback(imgPtr, "gpu-cache-full"); return fallback; }
+
+        // Full mip chain (box filter) — single-mip textures shimmer badly
+        // under minification at the echo's render scale.
+        uint32_t mips = 1;
+        { int m = slot->w > slot->h ? slot->w : slot->h; while (m > 1) { m >>= 1; mips++; } }
+
+        WGPUTextureDescriptor td = {};
+        td.size = { (uint32_t)slot->w, (uint32_t)slot->h, 1 };
+        td.mipLevelCount = mips;
+        td.sampleCount = 1;
+        td.dimension = WGPUTextureDimension_2D;
+        td.format = WGPUTextureFormat_RGBA8Unorm;
+        td.usage = WGPUTextureUsage_TextureBinding | WGPUTextureUsage_CopyDst;
+        WGPUTexture tex = wgpuDeviceCreateTexture(device, &td);
+        if (!tex) return fallback;
+
+        // Level 0 from the cache, then successive 2x box reductions.
+        int lw = slot->w, lh = slot->h;
+        uint8_t* cur = (uint8_t*)malloc((size_t)lw * lh * 4u);
+        memcpy(cur, slot->pixels, (size_t)lw * lh * 4u);
+        for (uint32_t level = 0; level < mips; ++level) {
+            WGPUTexelCopyTextureInfo dst = {};
+            dst.texture = tex;
+            dst.mipLevel = level;
+            WGPUTexelCopyBufferLayout layout = {};
+            layout.bytesPerRow = (uint32_t)lw * 4u;
+            layout.rowsPerImage = (uint32_t)lh;
+            WGPUExtent3D extent = { (uint32_t)lw, (uint32_t)lh, 1 };
+            wgpuQueueWriteTexture(queue, &dst, cur, (size_t)lw * lh * 4u, &layout, &extent);
+            if (level + 1 >= mips) break;
+            const int nw = lw > 1 ? lw >> 1 : 1, nh = lh > 1 ? lh >> 1 : 1;
+            uint8_t* next = (uint8_t*)malloc((size_t)nw * nh * 4u);
+            for (int y = 0; y < nh; ++y) {
+                const int sy0 = y * 2, sy1 = (sy0 + 1 < lh) ? sy0 + 1 : sy0;
+                for (int x = 0; x < nw; ++x) {
+                    const int sx0 = x * 2, sx1 = (sx0 + 1 < lw) ? sx0 + 1 : sx0;
+                    for (int c = 0; c < 4; ++c) {
+                        const int sum = cur[(sy0*lw+sx0)*4+c] + cur[(sy0*lw+sx1)*4+c]
+                                      + cur[(sy1*lw+sx0)*4+c] + cur[(sy1*lw+sx1)*4+c];
+                        next[(y*nw+x)*4+c] = (uint8_t)(sum >> 2);
+                    }
+                }
+            }
+            free(cur);
+            cur = next;
+            lw = nw; lh = nh;
+        }
+        free(cur);
+        WGPUTextureView view = wgpuTextureCreateView(tex, nullptr);
+        texCache[texCacheCount].ptr = imgPtr;
+        texCache[texCacheCount].view = view;
+        texCacheCount++;
+        // Diagnostic inventory: name, size, mid-pixel RGBA (first 12 uploads
+        // only — enough to validate the cache without flooding the console).
+        if (texCacheCount <= 12) {
+            const int mx = slot->w / 2, my = slot->h / 2;
+            const uint8_t* p = slot->pixels + ((size_t)my * slot->w + mx) * 4u;
+            EM_ASM_({
+                console.info("[d3] texUpload '" + UTF8ToString($0) + "' " + $1 + "x" + $2 +
+                             " mid=(" + $3 + "," + $4 + "," + $5 + "," + $6 + ")");
+            }, slot->name, slot->w, slot->h, p[0], p[1], p[2], p[3]);
+        }
+        return view;
+    }
+
+    // Iter 7b: material bind group (@group(1)) per unique 5-image tuple.
+    // imgs order matches the capture in draw_arb2.cpp:
+    //   [0]=bump [1]=lightFalloff [2]=lightProj [3]=diffuse [4]=specular
+    WGPUBindGroup getMaterialBindGroup(void* const imgs[5]) {
+        for (int i = 0; i < matCacheCount; ++i) {
+            if (memcmp(matCache[i].key, imgs, sizeof(void*) * 5) == 0) {
+                return matCache[i].group;
+            }
+        }
+        WGPUTextureView vNormal   = getEngineTextureView(imgs[0], fbFlatNormalView);
+        WGPUTextureView vFalloff  = getEngineTextureView(imgs[1], fbWhiteView);
+        WGPUTextureView vProj     = getEngineTextureView(imgs[2], fbWhiteView);
+        WGPUTextureView vDiffuse  = getEngineTextureView(imgs[3], fbCheckerView);
+        WGPUTextureView vSpecular = getEngineTextureView(imgs[4], fbWhiteView);
+        extern void* g_capSpecLUTPtr;
+        WGPUTextureView vSpecLUT  = getEngineTextureView(g_capSpecLUTPtr, fbWhiteView);
+        // Diagnostic: per-slot fallback misses. A falloff miss = the light
+        // extends forever along its axis (falloff=1) — giant washes.
+        {
+            const bool miss[5] = {
+                vNormal == fbFlatNormalView && imgs[0] != nullptr,
+                vFalloff == fbWhiteView     && imgs[1] != nullptr,
+                vProj == fbWhiteView        && imgs[2] != nullptr,
+                vDiffuse == fbCheckerView   && imgs[3] != nullptr,
+                vSpecular == fbWhiteView    && imgs[4] != nullptr,
+            };
+            if (miss[0] || miss[1] || miss[2] || miss[3] || miss[4]) {
+                EM_ASM_({
+                    console.info("[d3] matGroup MISS bump=" + $0 + " falloff=" + $1 +
+                                 " proj=" + $2 + " diffuse=" + $3 + " specular=" + $4);
+                }, (int)miss[0], (int)miss[1], (int)miss[2], (int)miss[3], (int)miss[4]);
+            }
+        }
+
+        WGPUBindGroupLayout bgl = wgpuRenderPipelineGetBindGroupLayout(interactionPipeline, 1);
+        // Scrolling light projections (lights/cloudscroll*: 'translate time')
+        // grow their texcoords unboundedly and MUST wrap — the single
+        // clamp-to-edge light sampler pinned them to the texture edge after
+        // ~30s of map time, silently killing those lights (the X360-vs-ours
+        // missing hangar floor pool + black marine). Honor the image's
+        // repeat mode for the projection; zeroClamp cookies keep clamp
+        // (WebGPU has no border color; edge-black cookies are equivalent).
+        const ImgSlot* projSlot = D3_WebGPU_LookupCachedImage(imgs[2]);
+        const bool projRepeats = projSlot && projSlot->repeat == 0;   // TR_REPEAT
+        WGPUBindGroupEntry e[8] = {};
+        e[0].binding = 0; e[0].sampler = interactionMaterialSampler;
+        e[1].binding = 1; e[1].sampler = projRepeats ? interactionMaterialSampler : interactionLightSampler;
+        e[2].binding = 2; e[2].textureView = vNormal;
+        e[3].binding = 3; e[3].textureView = vSpecular;
+        e[4].binding = 4; e[4].textureView = vDiffuse;
+        e[5].binding = 5; e[5].textureView = vFalloff;
+        e[6].binding = 6; e[6].textureView = vProj;
+        e[7].binding = 7; e[7].textureView = vSpecLUT;
+        WGPUBindGroupDescriptor bgd = {};
+        bgd.layout = bgl;
+        bgd.entryCount = 8;
+        bgd.entries = e;
+        WGPUBindGroup group = wgpuDeviceCreateBindGroup(device, &bgd);
+        wgpuBindGroupLayoutRelease(bgl);
+        if (matCacheCount < (int)kMatCacheSize) {
+            memcpy(matCache[matCacheCount].key, imgs, sizeof(void*) * 5);
+            matCache[matCacheCount].group = group;
+            matCacheCount++;
+        } else if (!matCacheOverflowWarned) {
+            matCacheOverflowWarned = true;
+            EM_ASM({ console.warn("[d3] WebGPU material bind-group cache full; transient groups will leak"); });
+        }
+        return group;
+    }
+
+    // Iter 7b: per-record slot resources. Each slot gets one 224-byte
+    // uniform buffer plus TWO group(0) bind groups over it: one for the
+    // interaction pipeline's layout, one for the depth pre-pass pipeline's
+    // layout (depth.wgsl only declares the mat4, so its auto layout has a
+    // smaller minBindingSize — entry.size 224 satisfies both). Fallback
+    // texture views are created here too.
+    void initRecordSlots() {
+        if (recordSlotsReady) return;
+        if (!interactionPipeline || !depthPipeline) return;
+
+        // Standard tangent-space flat normal (0,0,1) = RGB(128,128,255).
+        // Little-endian RGBA8 bytes R=0x80 G=0x80 B=0xFF A=0xFF.
+        fbFlatNormalView = makeFillTex(0xffff8080u, "fbFlatNormal");
+        fbWhiteView      = makeFillTex(0xffffffffu, "fbWhite");
+        fbCheckerView    = makeFillTex(0xff80c080u, "fbChecker");
+
+        WGPUBindGroupLayout bglInteraction = wgpuRenderPipelineGetBindGroupLayout(interactionPipeline, 0);
+        WGPUBindGroupLayout bglDepth       = wgpuRenderPipelineGetBindGroupLayout(depthPipeline, 0);
+        for (uint32_t i = 0; i < kMaxRecordSlots; ++i) {
+            // Iter 8c: per-slot uniform for shader-pass records (texture.wgsl
+            // layout: mvp + tint + params = 96 bytes).
+            WGPUBufferDescriptor pbd = {};
+            pbd.size = 128;
+            pbd.usage = WGPUBufferUsage_Uniform | WGPUBufferUsage_CopyDst;
+            passUniformBufs[i] = wgpuDeviceCreateBuffer(device, &pbd);
+
+            // Iter 9: per-slot shadow uniform (mvp + light origin = 80B)
+            if (shadowBGL) {
+                WGPUBufferDescriptor sbd = {};
+                sbd.size = 80;
+                sbd.usage = WGPUBufferUsage_Uniform | WGPUBufferUsage_CopyDst;
+                shadowUniformBufs[i] = wgpuDeviceCreateBuffer(device, &sbd);
+                WGPUBindGroupEntry se = {};
+                se.binding = 0; se.buffer = shadowUniformBufs[i]; se.size = 80;
+                WGPUBindGroupDescriptor sgd = {};
+                sgd.layout = shadowBGL;
+                sgd.entryCount = 1;
+                sgd.entries = &se;
+                shadowBindGroups[i] = wgpuDeviceCreateBindGroup(device, &sgd);
+            }
+
+            WGPUBufferDescriptor ubd = {};
+            ubd.size = 224;
+            ubd.usage = WGPUBufferUsage_Uniform | WGPUBufferUsage_CopyDst;
+            recordUniformBufs[i] = wgpuDeviceCreateBuffer(device, &ubd);
+            WGPUBindGroupEntry e = {};
+            e.binding = 0; e.buffer = recordUniformBufs[i]; e.size = 224;
+            WGPUBindGroupDescriptor bgd = {};
+            bgd.entryCount = 1;
+            bgd.entries = &e;
+            bgd.layout = bglInteraction;
+            recordBindGroups[i] = wgpuDeviceCreateBindGroup(device, &bgd);
+            bgd.layout = bglDepth;
+            recordDepthBindGroups[i] = wgpuDeviceCreateBindGroup(device, &bgd);
+        }
+        wgpuBindGroupLayoutRelease(bglInteraction);
+        wgpuBindGroupLayoutRelease(bglDepth);
+        recordSlotsReady = true;
+        EM_ASM_({ console.info("[d3] WebGPU record slots ready: " + $0); }, kMaxRecordSlots);
+    }
+
+    // Iter 6.6: copy CPU-side records → GPU buffers and CONSUME the
+    // accumulator (the engine appends across all of a frame's views; we
+    // drain here so a later RB_BeginDrawingView can't wipe records before
+    // we read them). When no fresh records exist this call, redraw the
+    // previous frame's set — the GPU buffers and uniforms are still valid
+    // (only happens on frames with no 3D view, where the camera can't move).
+    bool uploadCapturedRecords(uint32_t& outCount) {
+        extern Rec g_capRecords[];
+        extern uint8_t  g_capVertsAccum[];
+        extern uint16_t g_capIndexesAccum[];
+        extern uint32_t g_capRecordCount;
+        extern uint32_t g_capVertBytes;
+        extern uint32_t g_capIndexBytes;
+        extern uint32_t g_capFrameId;
+        extern uint32_t g_capDropped;
+        extern void* g_capImagePtrs[][5];
+
+        outCount = 0;
+        if (g_capRecordCount == 0) {
+            // No fresh capture — keep showing last frame's records if any.
+            outCount = lastRecordCount;
+            return lastRecordCount > 0;
+        }
+
+        const uint32_t vNeed = (g_capVertBytes + 3u) & ~3u;
+        const uint32_t iNeed = (g_capIndexBytes + 3u) & ~3u;
+        if (vNeed > recordVertexCap) {
+            if (recordVertexBuf) wgpuBufferRelease(recordVertexBuf);
+            uint32_t cap = vNeed; if (cap < 256*1024) cap = 256*1024;
+            WGPUBufferDescriptor d = {};
+            d.size = cap;
+            d.usage = WGPUBufferUsage_Vertex | WGPUBufferUsage_CopyDst;
+            recordVertexBuf = wgpuDeviceCreateBuffer(device, &d);
+            recordVertexCap = cap;
+        }
+        if (iNeed > recordIndexCap) {
+            if (recordIndexBuf) wgpuBufferRelease(recordIndexBuf);
+            uint32_t cap = iNeed; if (cap < 64*1024) cap = 64*1024;
+            WGPUBufferDescriptor d = {};
+            d.size = cap;
+            d.usage = WGPUBufferUsage_Index | WGPUBufferUsage_CopyDst;
+            recordIndexBuf = wgpuDeviceCreateBuffer(device, &d);
+            recordIndexCap = cap;
+        }
+        if (!recordVertexBuf || !recordIndexBuf) return false;
+        wgpuQueueWriteBuffer(queue, recordVertexBuf, 0, g_capVertsAccum,    vNeed);
+        wgpuQueueWriteBuffer(queue, recordIndexBuf,  0, g_capIndexesAccum,  iNeed);
+
+        uint32_t total = (g_capRecordCount < kMaxRecordSlots) ? g_capRecordCount : kMaxRecordSlots;
+        // Keep only the MAIN view's records. Subviews (mirrors, security
+        // monitors) render FIRST in idTech4, so the last record's view tag
+        // identifies the main view; records from other views would draw
+        // ghost geometry with alien projections. Compact in place.
+        uint32_t n = 0;
+        uint32_t mainN = 0;
+        subGroupCount = 0;
