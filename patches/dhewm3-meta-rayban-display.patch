+// Column-major 4x4 multiply (out = lhs * rhs), matching OpenGL storage.
+// Used to bake the full MVP per record at capture time — records can span
+// views (main view, subviews) with different projections, so a single
+// "last projection" global composed later would be wrong for all but the
+// last view's records.
+static void WGPU_MatMul4( float* out, const float* lhs, const float* rhs ) {
+	for ( int c = 0; c < 4; ++c ) {
+		for ( int r = 0; r < 4; ++r ) {
+			float s = 0.0f;
+			for ( int k = 0; k < 4; ++k ) {
+				s += lhs[k*4 + r] * rhs[c*4 + k];
+			}
+			out[c*4 + r] = s;
+		}
+	}
