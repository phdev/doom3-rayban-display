+/*
+===========================================================================
+
+Meta Ray-Ban Display wearable assist for dhewm3 (DOOM 3) — game module side.
+
+Mirrors the GLQuake II Display auto-fire / enemy-indicator assist. Only built
+for the Emscripten/WebAssembly target.
+
+===========================================================================
+*/
+
+#ifndef __D3_WEARABLE_GAME_H__
+#define __D3_WEARABLE_GAME_H__
+
+#ifdef __EMSCRIPTEN__
+
+class idPlayer;
+class usercmd_t;
+
+// Called once per player think, after the usercmd is latched. Updates the
+// left/right enemy indicators, snaps the view toward a side enemy when the
+// host requests a turn, and forces attack when a hostile is centered.
+void D3_WearablePlayerAssist( idPlayer *player, usercmd_t *cmd );
+
+#endif // __EMSCRIPTEN__
+
+#endif // __D3_WEARABLE_GAME_H__
