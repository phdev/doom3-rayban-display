+				ignoring = true;
+				continue;
+			}
+			ignoring = false;
 			com_numConsoleLines++;
 			com_consoleLines[ com_numConsoleLines-1 ].AppendArg( argv[ i ] + 1 );
 		} else {
+			// arguments of a dropped command must be dropped with it
+			if ( ignoring ) {
+				continue;
+			}
 			if ( !com_numConsoleLines ) {
 				com_numConsoleLines++;
