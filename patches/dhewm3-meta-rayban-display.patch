+}
+
+void D3_WebGPU_CapturePassStage( const drawSurf_t* surf, const srfTriangles_t* tri,
+                                 const shaderStage_t* pStage, const float color[4] ) {
+	if ( !backEnd.viewDef ) return;
+	// 2D GUI views (HUD, menus) have no view entities; they bypass the
+	// small-viewport filter (which exists to skip the lightgem) and are
+	// tagged so the backend draws them last with depth testing off.
+	const bool is2D = ( backEnd.viewDef->viewEntitys == NULL );
+	if ( !is2D && ( backEnd.viewDef->viewport.x2 - backEnd.viewDef->viewport.x1 ) < 128 ) return;
+	if ( !surf || !tri || !tri->verts || !tri->indexes ) return;
+	if ( tri->numVerts <= 0 || tri->numIndexes <= 0 ) return;
+	if ( tri->numVerts > kWGPUMaxCaptureVerts || tri->numIndexes > kWGPUMaxCaptureIndexes ) return;
+	// Iter 13b: sky cube stages — capture with the stashed per-vertex dirs.
+	const WGPUSkyStash* skyStash = nullptr;
+	if ( pStage->texture.texgen == TG_SKYBOX_CUBE || pStage->texture.texgen == TG_WOBBLESKY_CUBE ) {
+		skyStash = WGPU_FindSkyStash( surf );
+		if ( !skyStash || skyStash->numVerts != tri->numVerts ) return;
+		if ( g_skyDirBytes + (uint32_t)tri->numVerts * 12u > (uint32_t)kWGPUSkyDirBytes ) { g_capDropped++; return; }
+	} else if ( pStage->texture.texgen == TG_REFLECT_CUBE ) {
+		// handled below: pad3=3, modelView matrix rides the light fields.
+		// Iter 16: only OPAQUE env maps (chrome) replay correctly — the
+		// reflect pipeline draws opaque, so a translucent dst-alpha
+		// reflection (glass panes) would paint solid over the scene.
+		if ( ( pStage->drawStateBits & (GLS_SRCBLEND_BITS | GLS_DSTBLEND_BITS) ) != 0 ) {
+			return;
+		}
+	} else if ( pStage->texture.texgen != TG_EXPLICIT ) {
+		return;   // screen-space texgens still unsupported
+	}
+	// Iter 17: cinematic stages replay against the per-slot dynamic frame
+	// noted by RB_BindVariableStageImage moments ago.
+	uint32_t cinSlot = 0;
+	idImage* cinFallback = NULL;
+	if ( pStage->texture.cinematic ) {
+		if ( g_cinPendingSlot >= 0 ) {
+			cinSlot = (uint32_t)g_cinPendingSlot + 1u;   // sPad3 is 1-based; 0 = not cinematic
+			g_cinPendingSlot = -1;
+		} else {
+			// GL parity: with no decoded frame (r_skipROQ, missing video,
+			// idle decoder) GL binds blackImage and DRAWS — skipping the
+			// stage instead let the GUI backcolor show through as floating
+			// teal quads on every video screen.
+			cinFallback = globalImages->blackImage;
+		}
+	}
+	// Stages that mask off ALL color writes (maskcolor / makealpha — they
+	// only prime the alpha channel for a later gl_dst_alpha stage) must NOT
+	// be replayed: our pipelines write RGB, so they'd paint opaque blocks
+	// (found via glass1's alpha-prime stage painting the window white).
+	if ( ( pStage->drawStateBits & GLS_COLORMASK ) == GLS_COLORMASK ) return;
+	idImage* img = pStage->texture.image;
+	if ( cinFallback ) img = cinFallback;
+	if ( !img && !cinSlot ) return;
+	if ( g_passRecordCount >= (uint32_t)kWGPUMaxRecords ) { g_capDropped++; return; }
+
+	const uint32_t vbytes = (uint32_t)tri->numVerts * 60u;
+	const uint32_t ibytes = (uint32_t)tri->numIndexes * 2u;
+	const uint32_t vR = (vbytes + 3u) & ~3u;
