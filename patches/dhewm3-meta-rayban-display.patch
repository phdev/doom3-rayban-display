+            g_skyDirBytes = 0;
+        }
+
+        // Iter 17: upload this frame's decoded cinematic frames into the
+        // per-slot dynamic textures BEFORE the pass-record sweep builds
+        // bind groups against them, and retire last frame's transient
+        // groups (their submit has completed).
+        {
+            extern uint8_t  g_cinFrameBytes[][512 * 512 * 4];
+            extern int      g_cinFrameW[];
+            extern int      g_cinFrameH[];
+            extern uint32_t g_cinFrameCount;
+            for (uint32_t s = 0; s < kCinSlots; ++s) {
+                if (cinFrameGroups[s]) { wgpuBindGroupRelease(cinFrameGroups[s]); cinFrameGroups[s] = nullptr; }
