diff --git a/src/gl/shader.c b/src/gl/shader.c
index 0bde8f1..14fe0bd 100644
--- a/src/gl/shader.c
+++ b/src/gl/shader.c
@@ -176,6 +176,27 @@ void APIENTRY_GL4ES gl4es_glShaderSource(GLuint shader, GLsizei count, const GLc
             glshader->converted = strdup(glshader->source);
         else
             glshader->converted = ConvertShader(glshader->source, glshader->type==GL_VERTEX_SHADER?1:0, &glshader->need);
+        // Force gl_Position to be invariant in every vertex shader. DOOM 3 renders a
+        // depth pre-pass (fixed-function -> FPE shader) and then a lit interaction pass
+        // (ARB ftransform); both compute gl_Position from the same MVP*vertex, but as
+        // separate programs without 'invariant' a tile-based mobile GPU (iPhone) is free
+        // to optimize them differently, yielding slightly different depth so the lit
+        // pass's GL_EQUAL/GL_LEQUAL depth test rejects every fragment -> black scene.
+        // Desktop GPUs happen to match, so it only manifested on the device.
+        if(glshader->type==GL_VERTEX_SHADER && glshader->converted
+           && strstr(glshader->converted, "void main")
+           && !strstr(glshader->converted, "invariant gl_Position")) {
+            static const char* inv = "invariant gl_Position;\n";
+            char* at = strstr(glshader->converted, "void main");
+            size_t off = at - glshader->converted;
+            size_t invLen = strlen(inv), oldLen = strlen(glshader->converted);
+            char* nu = malloc(oldLen + invLen + 1);
+            memcpy(nu, glshader->converted, off);
+            memcpy(nu + off, inv, invLen);
+            strcpy(nu + off + invLen, glshader->converted + off);
+            free(glshader->converted);
+            glshader->converted = nu;
+        }
         // send source to GLES2 hardware if any
         gles_glShaderSource(shader, 1, (const GLchar * const*)((glshader->converted)?(&glshader->converted):(&glshader->source)), NULL);
         errorGL();
